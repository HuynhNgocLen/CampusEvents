@model List<shcool_event_management.Models.EVENT>
@{
    ViewBag.Title = "Quản lí sự kiện — CampusEvents Admin";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";

    int page      = (int)(ViewBag.Page ?? 1);
    int totalPage = (int)(ViewBag.TotalPage ?? 1);
    int total     = (int)(ViewBag.Total ?? 0);
    string search = ViewBag.Search as string;
    string status = ViewBag.Status as string;
    string cat    = ViewBag.Cat as string;
    string vien   = ViewBag.Vien as string;
    int? semester = ViewBag.Semester as int?;
    int? year     = ViewBag.Year as int?;
    var danhMucs  = ViewBag.DanhMucs as List<shcool_event_management.Models.DanhMuc>;

    Func<int, string> pageUrl = p => Url.Action("Manage", "AdminEvents",
        new { area = "Admin", page = p, search, status, cat, vien, semester, year });
}

@section styles {
<link href="@Url.Content("~/Content/campus-event-manage.css?v=3")" rel="stylesheet" />
}

<div class="ca-content">
    @Html.Partial("~/Areas/Admin/Views/AdminEvents/Manage/_Toolbar.cshtml", Model)
    @Html.Partial("~/Areas/Admin/Views/AdminEvents/Manage/_CardGrid.cshtml", Model)
    @Html.Partial("~/Areas/Admin/Views/AdminEvents/Manage/_ListView.cshtml", Model)

    @* ── Pagination ───────────────────────────────────────── *@
    @if (totalPage > 1)
    {
        <div class="em-pagination">
            <a class="em-page-btn @(page <= 1 ? "disabled" : "")" href="@pageUrl(page - 1)">
                <span class="material-symbols-outlined" style="font-size:16px">chevron_left</span>
            </a>
            @for (int p = Math.Max(1, page - 2); p <= Math.Min(totalPage, page + 2); p++)
            {
                <a class="em-page-btn @(p == page ? "active" : "")" href="@pageUrl(p)">@p</a>
            }
            <a class="em-page-btn @(page >= totalPage ? "disabled" : "")" href="@pageUrl(page + 1)">
                <span class="material-symbols-outlined" style="font-size:16px">chevron_right</span>
            </a>
        </div>
    }
    <br>
    @if (Model != null && Model.Any())
    {
        <p class="em-result-info">
            Hiển thị @Model.Count / @total sự kiện · Trang @page / @totalPage
            @if (!string.IsNullOrWhiteSpace(search))
            {
                <text> · kết quả cho "<strong>@search</strong>"</text>
            }
            @if (semester.HasValue)
            {
                <text> · Học kỳ @semester</text>
            }
            @if (year.HasValue)
            {
                <text> · Năm @year</text>
            }
        </p>
    }

</div>

@Html.Partial("~/Areas/Admin/Views/AdminEvents/Manage/_StudentModal.cshtml")

<div class="em-delete-modal-overlay" id="emDeleteModal" aria-hidden="true">
    <div class="em-delete-modal" role="dialog" aria-modal="true" aria-labelledby="emDeleteModalTitle">
        <div class="em-delete-modal__icon-wrap">
            <span class="material-symbols-outlined">event_busy</span>
        </div>
        <h3 id="emDeleteModalTitle" class="em-delete-modal__title">Bạn có chắc muốn xóa sự kiện?</h3>
        <p class="em-delete-modal__desc">
            Bạn sắp xóa vĩnh viễn sự kiện
            <strong id="emDeleteModalEventName"></strong>.
            Thao tác này không thể hoàn tác. Nếu không muốn xóa nữa, hãy chọn nút bên dưới để quay lại.
        </p>
        <div class="em-delete-modal__actions">
            <button type="button" class="ce-btn ce-btn-outline" id="emDeleteCancelBtn">Không xóa nữa</button>
            <button type="button" class="ce-btn ce-btn-danger" id="emDeleteConfirmBtn">Xác nhận xóa</button>
        </div>
    </div>
</div>

<div class="em-delete-modal-overlay" id="emCloseModal" aria-hidden="true">
    <div class="em-delete-modal" role="dialog" aria-modal="true" aria-labelledby="emCloseModalTitle">
        <div class="em-delete-modal__icon-wrap">
            <span class="material-symbols-outlined">event_busy</span>
        </div>
        <h3 id="emCloseModalTitle" class="em-delete-modal__title">Bạn có chắc muốn đóng sự kiện?</h3>
        <p class="em-delete-modal__desc">
            Sự kiện
            <strong id="emCloseModalEventName"></strong>
            <span id="emCloseModalDescAction">sẽ được cập nhật trạng thái <strong>Đã hủy</strong> và tự động ẩn khỏi hệ thống.</span>
        </p>
        <div class="em-delete-modal__actions">
            <button type="button" class="ce-btn ce-btn-outline" id="emCloseCancelBtn">Không đóng nữa</button>
            <button type="button" class="ce-btn ce-btn-danger" id="emCloseConfirmBtn">Xác nhận đóng</button>
        </div>
    </div>
</div>

@section scripts {
<script>
    var EM_CONFIG = {
        getStudentsUrl:  '@Url.Action("GetStudents","AdminEvents",new{area="Admin"})',
        updateStudentStatusUrl: '@Url.Action("UpdateStudentStatus","AdminEvents",new{area="Admin"})',
        closeEventUrl:   '@Url.Action("CloseEvent","AdminEvents",new{area="Admin"})',
        reopenEventUrl:  '@Url.Action("ReopenEvent","AdminEvents",new{area="Admin"})',
        exportExcelUrl:  '@Url.Action("ExportExcel","AdminEvents",new{area="Admin"})',
        toggleHiddenUrl: '@Url.Action("ToggleHidden","AdminEvents",new{area="Admin"})'
    };
</script>
<script src="@Url.Content("~/Scripts/A-event-manage.js")"></script>
}
