@model shcool_event_management.Models.EVENT
@{
    ViewBag.Title = "Tạo sự kiện mới — CampusEvents Admin";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
    var danhMucList = ViewBag.DanhMucList as List<SelectListItem>;
    var vienList = ViewBag.VienList as List<SelectListItem>;
    var diaDiemText = ViewBag.DiaDiemText as string;
    var isVienLocked = (bool?)(ViewBag.IsVienLocked) ?? false;
    var vienLockMessage = ViewBag.VienLockMessage as string;
    var minStartDate = DateTime.Today.AddDays(-20).ToString("yyyy-MM-dd");
}

@section styles {
<link href="@Url.Content("~/Content/campus-event-form.css?v=2")" rel="stylesheet" />
<link href="https://cdn.ckeditor.com/ckeditor5/41.1.0/classic/contents.css" rel="stylesheet" />

}

<div class="ca-content">
    <div class="ca-breadcrumb">
        <a href="@Url.Action("Dashboard","AdminDashboard",new{area="Admin"})">Dashboard</a>
        <span class="material-symbols-outlined" style="font-size:14px">chevron_right</span>
        <a href="@Url.Action("Manage","AdminEvents",new{area="Admin"})">Quản lí sự kiện</a>
        <span class="material-symbols-outlined" style="font-size:14px">chevron_right</span>
        <span>Tạo sự kiện mới</span>
    </div>

    <br>
    
    <div style="display:flex;align-items:center;justify-content:space-between;gap:.75rem;flex-wrap:wrap">
        <h1 class="ca-page-title">Tạo sự kiện mới</h1>
        <button type="button" class="ce-btn ce-btn-outline" id="btnCreateHelp">
            <span class="material-symbols-outlined">help</span>Hướng dẫn
        </button>
    </div>
    <p class="ca-page-sub">Điền đầy đủ thông tin bên dưới để xuất bản sự kiện lên hệ thống.</p>

    @Html.ValidationSummary(false, "", new { @class = "ce-alert ce-alert-error", style = "margin-bottom:1.25rem;" })

    @using (Html.BeginForm("Create","AdminEventPosts", new{area="Admin"}, FormMethod.Post, new { enctype="multipart/form-data", id="createForm" }))
    {
        @Html.AntiForgeryToken()
        <div class="ca-create-layout">
            <div>
                <div class="ca-card" style="margin-bottom:1.25rem">
                    <div class="ca-card__header">
                        <div class="ca-card__header-icon"><span class="material-symbols-outlined">info</span></div>
                        <div class="ca-card__title">Thông tin cơ bản</div>
                    </div>
                    <div class="ca-card__body">
                        <div class="ca-form-group">
                            <label class="ce-form-label">Tên sự kiện <span class="ca-required">*</span></label>
                            @Html.TextBoxFor(m => m.TenEvent, new { @class = "ce-form-control", placeholder = "VD: Hội thảo Chuyển đổi số 2025", maxlength = "200", id = "txtTenEvent" })
                            @Html.ValidationMessageFor(m => m.TenEvent, "", new { @class = "text-danger", style = "font-size:.76rem" })
                        </div>
                        <div class="form-row">
                            <div class="ca-form-group">
                                <label class="ce-form-label">Danh mục <span class="ca-required">*</span></label>
                                @Html.DropDownListFor(m => m.MaDanhMuc, danhMucList ?? new List<SelectListItem>(),
                                    "— Chọn danh mục —", new { @class = "ce-form-select" })
                                @Html.ValidationMessageFor(m => m.MaDanhMuc, "", new { @class = "text-danger", style = "font-size:.76rem" })
                            </div>
                            <div class="ca-form-group">
                                <label class="ce-form-label">Viện tổ chức <span class="ca-required">*</span></label>
                                @if (isVienLocked)
                                {
                                    @Html.DropDownListFor(m => m.MaVien, vienList ?? new List<SelectListItem>(),
                                        new { @class = "ce-form-select", @disabled = "disabled" })
                                    @Html.HiddenFor(m => m.MaVien)
                                    <div class="text-muted" style="font-size:.76rem; margin-top:.35rem">@vienLockMessage</div>
                                }
                                else
                                {
                                    @Html.DropDownListFor(m => m.MaVien, vienList ?? new List<SelectListItem>(),
                                        "— Chọn viện —", new { @class = "ce-form-select" })
                                }
                                @Html.ValidationMessageFor(m => m.MaVien, "", new { @class = "text-danger", style = "font-size:.76rem" })
                            </div>
                        </div>

                        <div class="ca-form-group">
                            <label class="ce-form-label">Địa điểm tổ chức <span class="ca-required">*</span></label>
                            <input type="text"
                                   name="diaDiemText"
                                   value="@diaDiemText"
                                   class="ce-form-control"
                                   maxlength="200"
                                   placeholder="VD: Hội trường A1 - Cơ sở 1" />
                            @Html.ValidationMessage("MaDiaDiem", "", new { @class = "text-danger", style = "font-size:.76rem" })
                        </div>
                        <div class="form-row-3">
                            <div class="ca-form-group">
                                <label class="ce-form-label">Ngày bắt đầu <span class="ca-required">*</span></label>
                                @Html.TextBoxFor(m => m.NgayBatDau, "{0:yyyy-MM-dd}",
                                    new { @class = "ce-form-control", type = "date", min = minStartDate, id = "ngayBatDauInput" })
                                <div class="text-muted" style="font-size:.76rem">Không được sớm hơn ngày hiện tại quá 20 ngày.</div>
                                @Html.ValidationMessageFor(m => m.NgayBatDau, "", new { @class = "text-danger", style = "font-size:.76rem" })
                            </div>
                            <div class="ca-form-group">
                                <label class="ce-form-label">Ngày kết thúc</label>
                                @Html.TextBoxFor(m => m.NgayKetThuc, "{0:yyyy-MM-dd}",
                                    new { @class = "ce-form-control", type = "date" })
                            </div>
                            <div class="ca-form-group">
                                <label class="ce-form-label">Hạn đăng ký</label>
                                @Html.TextBoxFor(m => m.NgayHetHanDangKy, "{0:yyyy-MM-dd}",
                                    new { @class = "ce-form-control", type = "date" })
                                <div class="text-muted" style="font-size:.76rem">Để trống nếu không giới hạn</div>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="ca-card" style="margin-bottom:1.25rem">
                    <div class="ca-card__header">
                        <div class="ca-card__header-icon"><span class="material-symbols-outlined">description</span></div>
                        <div class="ca-card__title">Nội dung sự kiện</div>
                    </div>
                    <div class="ca-card__body">
                        <div class="ca-form-group">
                            <label class="ce-form-label">Mô tả sự kiện</label>
                            @Html.TextAreaFor(m => m.MoTa, new { id = "richContent", rows = 10 })
                            @Html.ValidationMessageFor(m => m.MoTa, "", new { @class = "text-danger", style = "font-size:.76rem" })
                        </div>
                    </div>
                </div>

                <div class="ca-card" style="margin-bottom:1.25rem">
                    <div class="ca-card__header">
                        <div class="ca-card__header-icon"><span class="material-symbols-outlined">link</span></div>
                        <div class="ca-card__title">Liên kết & chi phí</div>
                    </div>
                    <div class="ca-card__body">
                        <div class="form-row">
                            <div class="ca-form-group">
                                <label class="ce-form-label">Link Zalo</label>
                                @Html.TextBoxFor(m => m.LinkZalo, new { @class = "ce-form-control", placeholder = "https://zalo.me/g/..." })
                            </div>
                            <div class="ca-form-group">
                                <label class="ce-form-label">Giá vé (VNĐ)</label>
                                @Html.TextBoxFor(m => m.GiaVe, new { @class = "ce-form-control", type = "number", min = 0, step = "1000", placeholder = "0" })
                            </div>
                        </div>
                    </div>
                </div>

                <div class="ca-card">
                    <div class="ca-card__header">
                        <div class="ca-card__header-icon"><span class="material-symbols-outlined">image</span></div>
                        <div class="ca-card__title">Ảnh bìa sự kiện</div>
                    </div>
                    <div class="ca-card__body">
                        <input type="file" id="coverImageInput" name="coverImage"
                               accept="image/jpeg,image/png" style="display:none"/>

                        <div class="ca-upload-zone" id="uploadZone" onclick="document.getElementById('coverImageInput').click()">
                            <span class="material-symbols-outlined">cloud_upload</span>
                            <div class="ca-upload-title">Kéo &amp; thả ảnh vào đây</div>
                            <div class="ca-upload-sub">hoặc click để chọn từ máy tính · JPG / PNG · Tối đa 5 MB · Khuyến nghị 1280×720px</div>
                        </div>

                        <div class="preview-wrap" id="previewWrap">
                            <img id="previewImg" src="" alt="Preview"/>
                            <button type="button" class="preview-remove" id="previewRemove" title="Xóa ảnh">
                                <span class="material-symbols-outlined">close</span>
                            </button>
                        </div>
                        <div style="margin-top:.6rem;display:flex;align-items:center;gap:.4rem;font-size:.73rem;color:var(--success);display:none" id="uploadQuality">
                            <span class="material-symbols-outlined" style="font-size:15px">check_circle</span>
                            Ảnh đạt chất lượng tốt
                        </div>
                    </div>
                </div>
            </div>

            <div class="ca-create-side">
                <div class="ca-card" style="margin-bottom:1.25rem">
                    <div class="ca-card__header">
                        <div class="ca-card__header-icon" style="background:var(--success-light,#dcfce7);color:var(--success)">
                            <span class="material-symbols-outlined">publish</span>
                        </div>
                        <div class="ca-card__title">Xuất bản</div>
                    </div>
                    <div class="ca-card__body">
                        <button type="submit" name="btnAction" value="publish" class="ce-btn ce-btn-primary ce-btn-block">
                            <span class="material-symbols-outlined">publish</span>Đăng sự kiện
                        </button>
                        <button type="submit" name="btnAction" value="draft" class="ce-btn ce-btn-outline ce-btn-block" style="margin-top:.5rem">
                            <span class="material-symbols-outlined">save</span>Lưu nháp
                        </button>
                        <a href="@Url.Action("Manage","AdminEvents",new{area="Admin"})"
                           class="ce-btn ce-btn-outline ce-btn-block js-cancel-event"
                           style="margin-top:.5rem;text-align:center;display:flex">
                            <span class="material-symbols-outlined">arrow_back</span>Hủy
                        </a>
                    </div>
                </div>

                <div class="ca-card" style="margin-bottom:1.25rem">
                    <div class="ca-card__header">
                        <div class="ca-card__header-icon"><span class="material-symbols-outlined">tune</span></div>
                        <div class="ca-card__title">Cài đặt đăng ký</div>
                    </div>
                    <div class="ca-card__body">
                        <div class="ca-form-group">
                            <label class="ce-form-label">Số lượng tối đa <span class="ca-required">*</span></label>
                            @Html.TextBoxFor(m => m.SoLuongToiDa, new { @class = "ce-form-control",
                                type = "number", min = 10, placeholder = "VD: 200" })
                            <div class="text-muted" style="font-size:.76rem">Tối thiểu 10 người</div>
                            @Html.ValidationMessageFor(m => m.SoLuongToiDa, "", new { @class = "text-danger", style = "font-size:.76rem" })
                        </div>
                        <div class="ca-form-group">
                            <label class="ce-form-label">Điểm rèn luyện (DRL)</label>
                            @Html.TextBoxFor(m => m.DRL, new { @class = "ce-form-control",
                                type = "number", min = 0, max = 20, placeholder = "0–20" })
                        </div>
                        <div class="ca-form-group">
                            <label class="ce-form-label">Trạng thái khởi tạo</label>
                            @Html.DropDownListFor(m => m.TrangThai, new List<SelectListItem>
                            {
                                new SelectListItem { Text = "Sắp diễn ra", Value = "Sắp diễn ra", Selected = true },
                                new SelectListItem { Text = "Bản nháp", Value = "Bản nháp" }
                            }, new { @class = "ce-form-select", id = "eventStatus" })
                            <div class="text-muted" style="font-size:.76rem">Nếu bấm “Lưu nháp” hệ thống vẫn tự chuyển về bản nháp.</div>
                        </div>
                        <div style="display:flex;align-items:center;justify-content:space-between;padding:.65rem 0;border-top:1px solid var(--border);margin-top:.25rem">
                            <div>
                                <div style="font-size:.84rem;font-weight:600">Ẩn sự kiện</div>
                                <div style="font-size:.72rem;color:var(--text-muted)">Không hiện trên trang chủ</div>
                            </div>
                            <label style="position:relative;display:inline-flex;align-items:center;cursor:pointer">
                                @Html.CheckBoxFor(m => m.IsHidden, new { id = "chkHidden", style = "opacity:0;width:0;height:0;position:absolute" })
                                <div id="switchTrack" style="width:40px;height:22px;background:var(--border);border-radius:999px;position:relative;transition:background .2s;cursor:pointer" onclick="toggleSwitch()">
                                    <div style="position:absolute;top:3px;left:3px;width:16px;height:16px;background:#fff;border-radius:50%;transition:transform .2s" id="switchThumb"></div>
                                </div>
                            </label>
                        </div>
                    </div>
                </div>

                <div class="ca-card">
                    <div class="ca-card__header">
                        <div class="ca-card__header-icon"><span class="material-symbols-outlined">preview</span></div>
                        <div class="ca-card__title">Xem trước thông tin</div>
                    </div>
                    <div class="ca-card__body" style="padding-top:.75rem">
                        <div class="stat-preview">
                            <div class="stat-preview__label">Đăng ký hiện tại</div>
                            <div class="stat-preview__val">0</div>
                        </div>
                        <div class="stat-preview">
                            <div class="stat-preview__label">Tỷ lệ lấp đầy</div>
                            <div class="stat-preview__val">0%</div>
                        </div>
                        <div style="font-size:.73rem;color:var(--text-muted);text-align:center;margin-top:.5rem">
                            Sự kiện mới — chưa có đăng ký
                        </div>
                    </div>
                </div>

            </div>
        </div>
    }
</div>

<div class="ce-modal-overlay" id="modal-create-help">
    <div class="ce-modal-box" style="max-width: 620px;">
        <div class="ce-modal-header">
            <h5>
                <span class="material-symbols-outlined" style="vertical-align:middle;margin-right:8px">help</span>
                Hướng dẫn tạo sự kiện
            </h5>
            <button class="ce-modal-close" type="button" id="btnCloseCreateHelp">
                <span class="material-symbols-outlined">close</span>
            </button>
        </div>
        <div class="ce-modal-body" style="font-size:.9rem;color:var(--text-muted);line-height:1.7">
            <p style="margin:0 0 .75rem 0"><strong style="color:var(--text)">Các trường bắt buộc không được để trống:</strong></p>
            <ul style="margin:0 0 1rem 1rem;padding:0">
                <li>Tên sự kiện</li>
                <li>Danh mục</li>
                <li>Viện tổ chức</li>
                <li>Địa điểm tổ chức</li>
                <li>Ngày bắt đầu</li>
                <li>Số lượng tối đa (ít nhất 10)</li>
                <li>Ảnh bìa (JPG/PNG, tối đa 5MB)</li>
            </ul>
            <p style="margin:0 0 .5rem 0"><strong style="color:var(--text)">Quy tắc xét ngày:</strong></p>
            <ul style="margin:0 0 1rem 1rem;padding:0">
                <li>Ngày bắt đầu không được nhỏ hơn ngày hiện tại quá 20 ngày.</li>
                <li>Ngày kết thúc (nếu có) phải bằng hoặc sau ngày bắt đầu.</li>
                <li>Hạn đăng ký (nếu có) phải trước ngày bắt đầu.</li>
            </ul>
            <p style="margin:0"><strong style="color:var(--text)">Phân quyền viện:</strong> tài khoản quyền 2 chỉ được tạo sự kiện cho viện gắn với tài khoản; quyền khác có thể chọn viện từ danh sách DB.</p>
        </div>
        <div class="ce-modal-footer">
            <button type="button" class="ce-btn ce-btn-primary" id="btnOkCreateHelp">Đã hiểu</button>
        </div>
    </div>
</div>

@section scripts {
<script src="https://cdn.ckeditor.com/ckeditor5/41.1.0/classic/ckeditor.js"></script>
<script src="@Url.Content("~/Scripts/A-event-create.js")"></script>
}
