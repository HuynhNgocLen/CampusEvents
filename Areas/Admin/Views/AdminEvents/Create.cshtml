@model shcool_event_management.Models.EVENT
@{
    ViewBag.Title = "Tạo sự kiện mới - Admin";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}

<div class="ca-content">
    <div class="ca-breadcrumb">
        <a href="@Url.Action("Index", "AdminEvents")">Quản lý sự kiện</a>
        <span class="sep">›</span>
        <span class="current">Tạo sự kiện mới</span>
    </div>

    <h1 class="ca-page-title">Tạo sự kiện mới</h1>
    <p class="ca-page-sub">Vui lòng nhập đầy đủ thông tin. Các trường có dấu <span class="text-danger">*</span> là bắt buộc.</p>

    @using (Html.BeginForm("Create", "AdminEvents", FormMethod.Post, new
    {
        enctype = "multipart/form-data",
        id = "createEventForm"
    }))
    {
        @Html.AntiForgeryToken()

        <div class="ca-create-layout">

            <!-- ==================== CỘT CHÍNH ==================== -->
            <div>

                <!-- 1. ẢNH BÌA -->
                <div class="ca-card">
                    <div class="ca-card__header">
                        <div class="ca-card__header-icon">
                            <span class="material-symbols-outlined">image</span>
                        </div>
                        <div class="ca-card__title">Ảnh bìa sự kiện <span class="text-danger">*</span></div>
                    </div>
                    <div class="ca-upload-zone" id="uploadZone">
                        <input type="file"
                               name="coverImage"
                               id="coverImageInput"
                               accept="image/jpeg,image/png"
                               required />

                        <div id="uploadContent">
                            <div class="ca-upload-icon-wrap">
                                <span class="material-symbols-outlined">cloud_upload</span>
                            </div>
                            <div class="ca-upload-title">Kéo thả hoặc click để chọn ảnh bìa</div>
                            <div class="ca-upload-sub">JPG / PNG • Tối đa 5 MB • Tỷ lệ khuyến nghị 16:9</div>
                        </div>

                        <div id="previewArea" class="ca-upload-preview" style="display: none;">
                            <img id="previewImg" src="" alt="Preview ảnh bìa">
                            <button type="button" id="removePreviewBtn" class="ca-upload-preview__remove">
                                <span class="material-symbols-outlined">close</span>
                            </button>
                        </div>
                    </div>
                </div>

                <!-- 2. THÔNG TIN CƠ BẢN -->
                <div class="ca-card">
                    <div class="ca-card__header">
                        <div class="ca-card__header-icon">
                            <span class="material-symbols-outlined">event</span>
                        </div>
                        <div class="ca-card__title">Thông tin cơ bản</div>
                    </div>

                    <div class="ca-form-group">
                        <label class="ce-form-label">Tên sự kiện <span class="text-danger">*</span></label>
                        @Html.TextBoxFor(m => m.TenEvent, new
                        {
                            @class = "ce-form-control",
                            placeholder = "Ví dụ: Annual Tech Symposium 2026",
                            required = "required",
                            maxlength = "250"
                        })
                    </div>

                    <div class="ca-form-row">
                        <div class="ca-form-group">
                            <label class="ce-form-label">Danh mục <span class="text-danger">*</span></label>
                            @Html.DropDownListFor(m => m.MaDanhMuc,
                                (IEnumerable<SelectListItem>)ViewBag.DanhMucList,
                                "-- Chọn danh mục --",
                                new { @class = "ce-form-select", required = "required" })
                        </div>

                        <div class="ca-form-group">
                            <label class="ce-form-label">Viện tổ chức <span class="text-danger">*</span></label>
                            @Html.DropDownListFor(m => m.MaVien,
                                (IEnumerable<SelectListItem>)ViewBag.VienList,
                                "-- Chọn viện --",
                                new { @class = "ce-form-select", required = "required" })
                        </div>
                    </div>

                    <div class="ca-form-group">
                        <label class="ce-form-label">Địa điểm <span class="text-danger">*</span></label>
                        @Html.DropDownListFor(m => m.MaDiaDiem,
                            (IEnumerable<SelectListItem>)ViewBag.DiaDiemList,
                            "-- Chọn địa điểm --",
                            new { @class = "ce-form-select", required = "required" })
                    </div>

                    <div class="ca-form-row">
                        <div class="ca-form-group">
                            <label class="ce-form-label">Email liên hệ</label>
                            @Html.TextBoxFor(m => m.Email, new
                            {
                                @class = "ce-form-control",
                                type = "email",
                                placeholder = "example@school.edu.vn"
                            })
                        </div>
                        <div class="ca-form-group">
                            <label class="ce-form-label">Link Zalo</label>
                            @Html.TextBoxFor(m => m.LinkZalo, new
                            {
                                @class = "ce-form-control",
                                placeholder = "https://zalo.me/..."
                            })
                        </div>
                    </div>
                </div>

                <!-- 3. THỜI GIAN SỰ KIỆN -->
                <div class="ca-card">
                    <div class="ca-card__header">
                        <div class="ca-card__header-icon">
                            <span class="material-symbols-outlined">schedule</span>
                        </div>
                        <div class="ca-card__title">Thời gian tổ chức sự kiện</div>
                    </div>

                    <div class="ca-form-row">
                        <div class="ca-form-group">
                            <label class="ce-form-label">Ngày & giờ bắt đầu <span class="text-danger">*</span></label>
                            <input type="datetime-local"
                                   name="NgayBatDau"
                                   class="ce-form-control"
                                   required />
                        </div>
                        <div class="ca-form-group">
                            <label class="ce-form-label">Ngày & giờ kết thúc</label>
                            <input type="datetime-local"
                                   name="NgayKetThuc"
                                   class="ce-form-control" />
                        </div>
                    </div>
                </div>

                <!-- 4. THỜI GIAN ĐĂNG KÝ -->
                <div class="ca-card">
                    <div class="ca-card__header">
                        <div class="ca-card__header-icon">
                            <span class="material-symbols-outlined">how_to_reg</span>
                        </div>
                        <div class="ca-card__title">Thời gian đăng ký</div>
                    </div>

                    <div class="ca-form-row">
                        <div class="ca-form-group">
                            <label class="ce-form-label">Bắt đầu đăng ký</label>
                            <input type="datetime-local"
                                   name="NgayBatDauDangKy"
                                   class="ce-form-control" />
                        </div>
                        <div class="ca-form-group">
                            <label class="ce-form-label">Hết hạn đăng ký <span class="text-danger">*</span></label>
                            <input type="date"
                                   name="NgayHetHanDangKy"
                                   class="ce-form-control"
                                   required />
                        </div>
                    </div>
                </div>

                <!-- 5. SỨC CHỨA & LỢI ÍCH -->
                <div class="ca-card">
                    <div class="ca-card__header">
                        <div class="ca-card__header-icon">
                            <span class="material-symbols-outlined">group</span>
                        </div>
                        <div class="ca-card__title">Sức chứa & Lợi ích</div>
                    </div>

                    <div class="ca-form-row">
                        <div class="ca-form-group">
                            <label class="ce-form-label">Số lượng tối đa <span class="text-danger">*</span></label>
                            <input type="number"
                                   name="SoLuongToiDa"
                                   value="200"
                                   min="10"
                                   class="ce-form-control"
                                   required />
                        </div>
                        <div class="ca-form-group">
                            <label class="ce-form-label">Giá vé (VND)</label>
                            <input type="number"
                                   name="GiaVe"
                                   value="0"
                                   min="0"
                                   step="1000"
                                   class="ce-form-control" />
                        </div>
                    </div>

                    <div class="ca-form-group">
                        <label class="ce-form-label">Điểm rèn luyện (DRL)</label>
                        <input type="number"
                               name="DRL"
                               value="0"
                               min="0"
                               class="ce-form-control" />
                    </div>
                </div>

                <!-- 6. MÔ TẢ NGẮN -->
                <div class="ca-card">
                    <div class="ca-card__header">
                        <div class="ca-card__header-icon">
                            <span class="material-symbols-outlined">description</span>
                        </div>
                        <div class="ca-card__title">Mô tả ngắn gọn</div>
                    </div>
                    <div class="ca-form-group">
                        @Html.TextAreaFor(m => m.MoTa, new
                        {
                            @class = "ce-form-control",
                            rows = "4",
                            placeholder = "Mô tả ngắn sẽ hiển thị ở trang chủ..."
                        })
                    </div>
                </div>

                <!-- 7. NỘI DUNG CHI TIẾT - CKEDITOR 5 -->
                <div class="ca-card">
                    <div class="ca-card__header">
                        <div class="ca-card__header-icon">
                            <span class="material-symbols-outlined">article</span>
                        </div>
                        <div class="ca-card__title">Nội dung chi tiết sự kiện <span class="text-danger">*</span></div>
                    </div>
                    <div class="ca-form-group">
                        <label class="ce-form-label">Nhập chi tiết chương trình, lịch trình, quy định, diễn giả...</label>
                        @Html.TextAreaFor(m => m.ChiTiet, new
                        {
                            id = "ChiTietEditor",
                            @class = "ce-form-control",
                            rows = "14",
                            style = "display:none;"
                        })
                    </div>
                </div>

            </div>

            <!-- ==================== SIDEBAR ==================== -->
            <div class="ca-create-side">
                <div class="ca-card">
                    <div class="ca-card__header">
                        <div class="ca-card__header-icon">
                            <span class="material-symbols-outlined">check_circle</span>
                        </div>
                        <div class="ca-card__title">Kiểm tra trước khi đăng</div>
                    </div>
                    <ul style="font-size:0.85rem; line-height:1.6; padding-left:1.25rem; margin:0; color:var(--text-muted);">
                        <li>Ảnh bìa rõ nét, kích thước phù hợp</li>
                        <li>Thời gian bắt đầu phải sau thời điểm hiện tại</li>
                        <li>Hạn đăng ký phải trước ngày bắt đầu sự kiện</li>
                        <li>Số lượng tối đa ≥ 10 người</li>
                        <li>Đã chọn đầy đủ: Tên, Danh mục, Viện, Địa điểm</li>
                    </ul>
                </div>
            </div>
        </div>

        <!-- NÚT HÀNH ĐỘNG -->
        <div style="margin-top: 2.5rem; padding-top: 1.5rem; border-top: 1px solid var(--border); display: flex; gap: 1rem; justify-content: flex-end;">
            <button type="submit"
                    name="btnAction"
                    value="draft"
                    class="ce-btn ce-btn-ghost ce-btn-lg">
                <span class="material-symbols-outlined">save</span>
                Lưu bản nháp
            </button>

            <button type="submit"
                    name="btnAction"
                    value="publish"
                    class="ce-btn ce-btn-primary ce-btn-lg">
                <span class="material-symbols-outlined">send</span>
                Đăng sự kiện ngay
            </button>
        </div>
    }
</div>

<!-- ========================== CKEDITOR 5 (ĐÃ SỬA LỖI) ========================== -->
<link rel="stylesheet" href="https://cdn.ckeditor.com/ckeditor5/48.0.0/ckeditor5.css" />
<script src="https://cdn.ckeditor.com/ckeditor5/48.0.0/ckeditor5.umd.js"></script>

<script>
    document.addEventListener('DOMContentLoaded', function () {
        let editorInstance = null;

        // Sửa lỗi ClassicEditor is not defined
        const CK = window.CKEDITOR || window.ClassicEditor;
        if (typeof CK === 'undefined' || typeof CK.ClassicEditor === 'undefined') {
            console.error('❌ CKEditor 5 chưa tải. Vui lòng kiểm tra kết nối mạng hoặc CDN.');
            return;
        }

        const ClassicEditor = CK.ClassicEditor || CK;

        ClassicEditor
            .create(document.querySelector('#ChiTietEditor'), {
                language: {
                    ui: 'vi',
                    content: 'vi'
                },
                toolbar: {
                    items: [
                        'heading', '|',
                        'bold', 'italic', 'underline', '|',
                        'fontSize', 'fontColor', 'fontBackgroundColor', '|',
                        'bulletedList', 'numberedList', '|',
                        'alignment', 'link', 'blockQuote', 'insertTable', '|',
                        'undo', 'redo'
                    ]
                },
                placeholder: 'Nhập nội dung chi tiết sự kiện tại đây...',
                height: '420px'
            })
            .then(editor => {
                editorInstance = editor;
                console.log('✅ CKEditor 5 đã khởi tạo thành công!');
            })
            .catch(error => {
                console.error('❌ Lỗi khởi tạo CKEditor:', error);
            });

        // Copy dữ liệu từ CKEditor vào textarea trước khi submit
        const form = document.getElementById('createEventForm');
        if (form) {
            form.addEventListener('submit', function () {
                if (editorInstance) {
                    document.getElementById('ChiTietEditor').value = editorInstance.getData();
                }
            });
        }

        // Preview ảnh bìa
        const fileInput = document.getElementById('coverImageInput');
        const uploadContent = document.getElementById('uploadContent');
        const previewArea = document.getElementById('previewArea');
        const previewImg = document.getElementById('previewImg');
        const removeBtn = document.getElementById('removePreviewBtn');

        fileInput.addEventListener('change', function () {
            if (this.files && this.files[0]) {
                const reader = new FileReader();
                reader.onload = function (e) {
                    previewImg.src = e.target.result;
                    uploadContent.style.display = 'none';
                    previewArea.style.display = 'block';
                };
                reader.readAsDataURL(this.files[0]);
            }
        });

        removeBtn.addEventListener('click', function (e) {
            e.preventDefault();
            fileInput.value = '';
            previewArea.style.display = 'none';
            uploadContent.style.display = 'block';
        });
    });
</script>