@model List<shcool_event_management.Models.EVENT>
@{
    ViewBag.Title = "Sự kiện — CampusEvents Admin";
    ViewBag.ActiveMenu = "events";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
    var danhMucs = ViewBag.DanhMucs as List<shcool_event_management.Models.DanhMuc>;
    var currentCat = ViewBag.CurrentCat as string;
    var currentSearch = ViewBag.CurrentSearch as string;
}

@section styles {
<style>
.filter-chips { display:flex; gap:.5rem; flex-wrap:wrap; margin-bottom:1.5rem; }
.chip {
    padding:.35rem 1rem; border-radius:999px; font-size:.78rem; font-weight:600;
    border:1.5px solid var(--border); background:var(--surface); color:var(--text-muted);
    text-decoration:none; transition:all .18s;
}
.chip:hover, .chip.active {
    background:var(--primary-light); color:var(--primary);
    border-color:rgba(19,127,236,.35);
}
.event-grid {
    display:grid;
    grid-template-columns:repeat(auto-fill, minmax(300px,1fr));
    gap:1.25rem;
    margin-bottom:2rem;
}
.ev-card {
    background:var(--surface); border:1px solid var(--border);
    border-radius:var(--radius-lg); overflow:hidden;
    transition:transform .2s, box-shadow .2s;
    display:flex; flex-direction:column;
}
.ev-card:hover { transform:translateY(-3px); box-shadow:0 8px 24px rgba(0,0,0,.1); }
.ev-card__thumb {
    height:168px; position:relative; overflow:hidden;
    background:linear-gradient(135deg,#1e40af,#0ea5e9);
}
.ev-card__thumb img { width:100%; height:100%; object-fit:cover; }
.ev-card__thumb-placeholder {
    display:flex; align-items:center; justify-content:center; height:100%;
    color:rgba(255,255,255,.3);
}
.ev-card__thumb-placeholder .material-symbols-outlined { font-size:52px; }
.ev-card__cat {
    position:absolute; top:.75rem; left:.75rem;
    background:rgba(0,0,0,.35); backdrop-filter:blur(6px);
    color:#fff; font-size:.67rem; font-weight:700;
    padding:.2rem .65rem; border-radius:999px; letter-spacing:.04em;
}
.ev-card__status-badge { position:absolute; top:.75rem; right:.75rem; }
.ev-card__hidden-badge {
    position:absolute; bottom:.6rem; left:.75rem;
    background:rgba(0,0,0,.55); color:#fff; font-size:.67rem; font-weight:700;
    padding:.15rem .55rem; border-radius:999px;
    display:flex; align-items:center; gap:.25rem;
}
.ev-card__hidden-badge .material-symbols-outlined { font-size:12px; }
.ev-card__body { padding:1rem 1.1rem; flex:1; }
.ev-card__title {
    font-size:.92rem; font-weight:700; margin-bottom:.5rem; line-height:1.35;
    display:-webkit-box; -webkit-line-clamp:2; -webkit-box-orient:vertical; overflow:hidden;
}
.ev-card__meta { display:flex; flex-direction:column; gap:.22rem; }
.ev-card__meta-row {
    display:flex; align-items:center; gap:.35rem;
    font-size:.75rem; color:var(--text-muted);
}
.ev-card__meta-row .material-symbols-outlined { font-size:14px; color:var(--text-light); flex-shrink:0; }
.ev-card__footer {
    padding:.75rem 1.1rem; border-top:1px solid var(--border);
    display:flex; align-items:center; justify-content:space-between; gap:.75rem;
}
.ev-card__progress { flex:1; }
.prog-wrap { display:flex; align-items:center; gap:.5rem; }
.prog-bg { flex:1; height:5px; background:var(--border); border-radius:999px; overflow:hidden; }
.prog-fill { height:100%; background:var(--primary); border-radius:999px; transition:width .4s; }
.prog-label { font-size:.69rem; color:var(--text-muted); white-space:nowrap; }
.ev-card__actions { display:flex; gap:.35rem; flex-shrink:0; }

.empty-state {
    grid-column:1/-1; text-align:center; padding:4rem 2rem;
    color:var(--text-muted);
}
.empty-state .material-symbols-outlined { font-size:56px; color:var(--text-light); margin-bottom:1rem; }
.empty-state h3 { font-size:1.1rem; font-weight:700; color:var(--text); margin-bottom:.4rem; }
.empty-state p { font-size:.85rem; }
</style>
}

<div class="ca-content">
    <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:.35rem;">
        <div>
            <h1 class="ca-page-title">Sự kiện</h1>
        </div>
        <a href="@Url.Action("Create","AdminEvents",new{area="Admin"})" class="ce-btn ce-btn-primary">
            <span class="material-symbols-outlined">add</span>Tạo sự kiện mới
        </a>
    </div>
    <p class="ca-page-sub">Duyệt và lọc toàn bộ sự kiện đang hoạt động trên hệ thống.</p>

    @* Search + filter *@
    <form method="get" action="@Url.Action("Index","AdminEvents",new{area="Admin"})" style="display:flex;gap:.75rem;margin-bottom:1.25rem;flex-wrap:wrap;">
        <div style="position:relative;flex:1;max-width:360px;">
            <span class="material-symbols-outlined" style="position:absolute;left:.7rem;top:50%;transform:translateY(-50%);font-size:17px;color:var(--text-light);pointer-events:none;">search</span>
            <input name="search" value="@currentSearch" type="search"
                   placeholder="Tìm kiếm sự kiện..."
                   style="width:100%;height:38px;padding:0 1rem 0 2.4rem;border-radius:999px;border:1.5px solid var(--border);background:var(--surface-2);color:var(--text);font-family:var(--font-main);font-size:.83rem;outline:none;"/>
        </div>
        @if (!string.IsNullOrWhiteSpace(currentCat))
        {
            <input type="hidden" name="cat" value="@currentCat"/>
        }
        <button type="submit" class="ce-btn ce-btn-outline">
            <span class="material-symbols-outlined">search</span>Tìm
        </button>
        @if (!string.IsNullOrWhiteSpace(currentSearch))
        {
            <a href="@Url.Action("Index","AdminEvents",new{area="Admin",cat=currentCat})" class="ce-btn ce-btn-outline">
                <span class="material-symbols-outlined">close</span>Xóa tìm kiếm
            </a>
        }
    </form>

    @* Category chip filters *@
    <div class="filter-chips">
        <a class="chip @(string.IsNullOrWhiteSpace(currentCat) ? "active" : "")"
           href="@Url.Action("Index","AdminEvents",new{area="Admin",search=currentSearch})">
            Tất cả
        </a>
        @if (danhMucs != null)
        {
            foreach (var dm in danhMucs)
            {
                <a class="chip @(currentCat == dm.MaDanhMuc ? "active" : "")"
                   href="@Url.Action("Index","AdminEvents",new{area="Admin",cat=dm.MaDanhMuc,search=currentSearch})">
                    @dm.TenDanhMuc
                </a>
            }
        }
    </div>

    @* Event grid *@
    <div class="event-grid">
        @if (Model == null || !Model.Any())
        {
            <div class="empty-state">
                <span class="material-symbols-outlined">event_busy</span>
                <h3>Không tìm thấy sự kiện nào</h3>
                <p>Thử thay đổi bộ lọc hoặc từ khoá tìm kiếm.</p>
            </div>
        }
        else
        {
            foreach (var ev in Model)
            {
                double pct = ev.SoLuongToiDa > 0
                    ? Math.Round(ev.SoLuongDaDangKy * 100.0 / ev.SoLuongToiDa, 0) : 0;

                string statusClass = ev.TrangThai == "Sắp diễn ra" ? "ce-badge ce-badge-info"
                    : ev.TrangThai == "Đang diễn ra" ? "ce-badge ce-badge-success"
                    : ev.TrangThai == "Đã hủy" ? "ce-badge ce-badge-danger"
                    : "ce-badge ce-badge-default";

                <div class="ev-card">
                    <div class="ev-card__thumb">
                        @if (!string.IsNullOrEmpty(ev.AnhBia))
                        {
                            <img src="@Url.Content("~/Uploads/Events/" + ev.AnhBia)" alt="@ev.TenEvent"/>
                        }
                        else
                        {
                            <div class="ev-card__thumb-placeholder">
                                <span class="material-symbols-outlined">event</span>
                            </div>
                        }
                        @if (ev.DanhMuc != null)
                        {
                            <span class="ev-card__cat">@ev.DanhMuc.TenDanhMuc</span>
                        }
                        <div class="ev-card__status-badge">
                            <span class="@statusClass">@ev.TrangThai</span>
                        </div>
                        @if (ev.IsHidden == true)
                        {
                            <div class="ev-card__hidden-badge">
                                <span class="material-symbols-outlined">visibility_off</span>Đã ẩn
                            </div>
                        }
                    </div>

                    <div class="ev-card__body">
                        <div class="ev-card__title">@ev.TenEvent</div>
                        <div class="ev-card__meta">
                            <div class="ev-card__meta-row">
                                <span class="material-symbols-outlined">calendar_today</span>
                                @ev.NgayBatDau.ToString("dd/MM/yyyy HH:mm")
                            </div>
                            @if (ev.DiaDiem != null)
                            {
                                <div class="ev-card__meta-row">
                                    <span class="material-symbols-outlined">location_on</span>
                                    @ev.DiaDiem.TenDiaDiem
                                </div>
                            }
                            <div class="ev-card__meta-row">
                                <span class="material-symbols-outlined">corporate_fare</span>
                                @ev.MaVien
                            </div>
                        </div>
                    </div>

                    <div class="ev-card__footer">
                        <div class="ev-card__progress">
                            <div class="prog-wrap">
                                <div class="prog-bg">
                                    <div class="prog-fill" style="width:@pct%"></div>
                                </div>
                                <span class="prog-label">@ev.SoLuongDaDangKy/@ev.SoLuongToiDa</span>
                            </div>
                        </div>
                        <div class="ev-card__actions">
                            <a href="@Url.Action("RegistrationDetail","AdminEvents",new{area="Admin",id=ev.MaEvent})"
                               class="ce-btn ce-btn-sm ce-btn-outline" title="Danh sách đăng ký">
                                <span class="material-symbols-outlined">group</span>
                            </a>
                            <a href="@Url.Action("Edit","AdminEvents",new{area="Admin",id=ev.MaEvent})"
                               class="ce-btn ce-btn-sm ce-btn-outline" title="Chỉnh sửa">
                                <span class="material-symbols-outlined">edit</span>
                            </a>
                        </div>
                    </div>
                </div>
            }
        }
    </div>

    @if (Model != null && Model.Any())
    {
        <p style="font-size:.78rem;color:var(--text-muted);text-align:center;">
            Hiển thị @Model.Count sự kiện
            @if (!string.IsNullOrWhiteSpace(currentSearch)) { <text> · kết quả cho "<strong>@currentSearch</strong>"</text> }
        </p>
    }
</div>
