@model List<shcool_event_management.Models.DangKySuKien>
@{
    ViewBag.Title = "Chi tiết đăng ký — CampusEvents Admin";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
    var ev       = ViewBag.Event as shcool_event_management.Models.EVENT;
    int totalReg = (int)(ViewBag.TotalReg   ?? 0);
    int confirmed= (int)(ViewBag.Confirmed  ?? 0);
    int cancelled= (int)(ViewBag.Cancelled  ?? 0);
    int page     = (int)(ViewBag.Page       ?? 1);
    int totalPage= (int)(ViewBag.TotalPage  ?? 1);
    string search= ViewBag.Search as string;
    string status= ViewBag.Status as string;

    Func<int,string> pageUrl = p => Url.Action("RegistrationDetail","AdminEvents",
        new{area="Admin",id=ev?.MaEvent,page=p,search,status});
    double pct = ev != null && ev.SoLuongToiDa > 0
        ? Math.Round(ev.SoLuongDaDangKy * 100.0 / ev.SoLuongToiDa,1) : 0;
}

@section styles {
<style>
.reg-kpi-row { display:grid; grid-template-columns:repeat(4,1fr); gap:1rem; margin-bottom:1.5rem; }
.reg-kpi { background:var(--surface); border:1px solid var(--border); border-radius:var(--radius-lg); padding:1rem 1.25rem; box-shadow:var(--shadow-sm); }
.reg-kpi__label { font-size:.67rem; font-weight:700; text-transform:uppercase; letter-spacing:.07em; color:var(--text-muted); margin-bottom:.3rem; }
.reg-kpi__val { font-size:1.8rem; font-weight:800; line-height:1; }
.page-btn { width:32px; height:32px; border-radius:var(--radius); border:1px solid var(--border); background:var(--surface); font-family:var(--font-main); font-size:.78rem; font-weight:600; color:var(--text-muted); cursor:pointer; display:flex; align-items:center; justify-content:center; text-decoration:none; transition:all .18s; }
.page-btn:hover, .page-btn.active { background:var(--primary); color:#fff; border-color:var(--primary); }
.page-btn.disabled { opacity:.4; pointer-events:none; }
.prog-wrap { display:flex; align-items:center; gap:.5rem; }
.prog-bg { flex:1; height:6px; background:var(--border); border-radius:999px; overflow:hidden; }
.prog-fill { height:100%; border-radius:999px; }
</style>
}

<div class="ca-content">
    <div class="ca-breadcrumb">
        <a href="@Url.Action("Dashboard","AdminDashboard",new{area="Admin"})">Dashboard</a>
        <span class="material-symbols-outlined" style="font-size:14px">chevron_right</span>
        <a href="@Url.Action("Manage","AdminEvents",new{area="Admin"})">Quản lý bài đăng</a>
        <span class="material-symbols-outlined" style="font-size:14px">chevron_right</span>
        <span>Chi tiết đăng ký</span>
    </div>

    @if (ev != null)
    {
        @* Event info banner *@
        <div class="ca-card" style="margin-bottom:1.5rem">
            <div class="ca-card__body" style="padding:1.25rem 1.5rem">
                <div style="display:flex;align-items:flex-start;justify-content:space-between;gap:1rem;flex-wrap:wrap">
                    <div>
                        <h1 class="ca-page-title" style="margin-bottom:.4rem;font-size:1.45rem">@ev.TenEvent</h1>
                        <div style="display:flex;flex-wrap:wrap;gap:.75rem;font-size:.8rem;color:var(--text-muted)">
                            <span style="display:flex;align-items:center;gap:.3rem">
                                <span class="material-symbols-outlined" style="font-size:15px">calendar_today</span>
                                @ev.NgayBatDau.ToString("dd/MM/yyyy HH:mm")
                            </span>
                            @if (ev.DiaDiem != null)
                            {
                                <span style="display:flex;align-items:center;gap:.3rem">
                                    <span class="material-symbols-outlined" style="font-size:15px">location_on</span>
                                    @ev.DiaDiem.TenDiaDiem
                                </span>
                            }
                            <span style="display:flex;align-items:center;gap:.3rem">
                                <span class="material-symbols-outlined" style="font-size:15px">corporate_fare</span>
                                @ev.MaVien
                            </span>
                        </div>
                        <div style="margin-top:.85rem">
                            <div class="prog-wrap" style="max-width:320px">
                                <div class="prog-bg">
                                    <div class="prog-fill" style="width:@pct%;background:@(pct>=90?"var(--danger)":pct>=60?"var(--warning)":"var(--primary)")"></div>
                                </div>
                                <span style="font-size:.78rem;color:var(--text-muted);white-space:nowrap">
                                    @ev.SoLuongDaDangKy / @ev.SoLuongToiDa người · @pct%
                                </span>
                            </div>
                        </div>
                    </div>
                    <div style="display:flex;gap:.5rem;flex-shrink:0">
                        <a href="@Url.Action("ExportExcel","AdminEvents",new{area="Admin",id=ev.MaEvent})"
                           class="ce-btn ce-btn-outline">
                            <span class="material-symbols-outlined">download</span>Xuất Excel
                        </a>
                        <a href="@Url.Action("Edit","AdminEvents",new{area="Admin",id=ev.MaEvent})"
                           class="ce-btn ce-btn-outline">
                            <span class="material-symbols-outlined">edit</span>Sửa sự kiện
                        </a>
                    </div>
                </div>
            </div>
        </div>

        @* KPI *@
        <div class="reg-kpi-row">
            <div class="reg-kpi">
                <div class="reg-kpi__label">Tổng đăng ký</div>
                <div class="reg-kpi__val" style="color:var(--primary)">@totalReg</div>
            </div>
            <div class="reg-kpi">
                <div class="reg-kpi__label">Đã xác nhận</div>
                <div class="reg-kpi__val" style="color:var(--success)">@confirmed</div>
            </div>
            <div class="reg-kpi">
                <div class="reg-kpi__label">Đã hủy</div>
                <div class="reg-kpi__val" style="color:var(--danger)">@cancelled</div>
            </div>
            <div class="reg-kpi">
                <div class="reg-kpi__label">Chờ xác nhận</div>
                <div class="reg-kpi__val" style="color:var(--warning)">@(totalReg - confirmed - cancelled)</div>
            </div>
        </div>
    }

    @* Filter bar *@
    <form method="get" action="@Url.Action("RegistrationDetail","AdminEvents",new{area="Admin",id=ev?.MaEvent})"
          style="display:flex;gap:.65rem;align-items:center;flex-wrap:wrap;background:var(--surface);border:1px solid var(--border);border-radius:var(--radius-lg);padding:.875rem 1.1rem;margin-bottom:1.25rem;box-shadow:var(--shadow-sm)">
        <span class="material-symbols-outlined" style="font-size:18px;color:var(--text-light)">filter_list</span>
        <div style="position:relative;flex:1;max-width:280px">
            <span class="material-symbols-outlined" style="position:absolute;left:.6rem;top:50%;transform:translateY(-50%);font-size:16px;color:var(--text-light);pointer-events:none">search</span>
            <input type="search" name="search" value="@search" placeholder="Tìm tên / MSSV..."
                   style="width:100%;height:36px;padding:0 .75rem 0 2.1rem;border:1.5px solid var(--border);border-radius:var(--radius);background:var(--surface-2);color:var(--text);font-family:var(--font-main);font-size:.82rem;outline:none"/>
        </div>
        <select name="status"
                style="height:36px;padding:0 .75rem;border:1.5px solid var(--border);border-radius:var(--radius);background:var(--surface-2);color:var(--text);font-family:var(--font-main);font-size:.82rem;outline:none">
            <option value="">Tất cả trạng thái</option>
            <option value="Đã xác nhận"  @(status=="Đã xác nhận"?"selected":"")>Đã xác nhận</option>
            <option value="Chờ xác nhận" @(status=="Chờ xác nhận"?"selected":"")>Chờ xác nhận</option>
            <option value="Đã hủy"       @(status=="Đã hủy"?"selected":"")>Đã hủy</option>
        </select>
        <button type="submit" class="ce-btn ce-btn-primary ce-btn-sm">
            <span class="material-symbols-outlined">search</span>Lọc
        </button>
        @if (!string.IsNullOrWhiteSpace(search) || !string.IsNullOrWhiteSpace(status))
        {
            <a href="@Url.Action("RegistrationDetail","AdminEvents",new{area="Admin",id=ev?.MaEvent})"
               class="ce-btn ce-btn-outline ce-btn-sm"><span class="material-symbols-outlined">close</span>Xóa lọc</a>
        }
    </form>

    @* Table *@
    <div class="ca-table-wrap">
        <div class="ca-table-toolbar">
            <div class="ca-table-toolbar__title">
                <span class="material-symbols-outlined" style="font-size:18px;color:var(--primary)">group</span>
                Danh sách sinh viên đăng ký
                <span class="ca-table-count">@totalReg người</span>
            </div>
        </div>
        <div class="ca-table-scroll">
            <table class="ca-table">
                <thead>
                    <tr>
                        <th style="width:40px">#</th>
                        <th>Sinh viên</th>
                        <th>Lớp / Ngành</th>
                        <th>Email</th>
                        <th>SĐT</th>
                        <th>Ngày đăng ký</th>
                        <th>Trạng thái</th>
                        <th style="width:100px;text-align:center">Thao tác</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model == null || !Model.Any())
                    {
                        <tr>
                            <td colspan="8" style="text-align:center;padding:3rem 1rem;color:var(--text-muted)">
                                <span class="material-symbols-outlined" style="font-size:36px;display:block;margin-bottom:.5rem;color:var(--text-light)">person_off</span>
                                Chưa có sinh viên đăng ký
                            </td>
                        </tr>
                    }
                    else
                    {
                        int idx = (page - 1) * (int)(ViewBag.PageSize ?? 20) + 1;
                        foreach (var reg in Model)
                        {
                            var sv = reg.SinhVien;
                            string initials = sv != null && !string.IsNullOrEmpty(sv.Ten)
                                ? sv.Ten.Split(' ').LastOrDefault()?.Substring(0,1).ToUpper() ?? "?" : "?";

                            string regBadge = reg.TrangThai == "Đã xác nhận" ? "ce-badge ce-badge-success"
                                : reg.TrangThai == "Đã hủy" ? "ce-badge ce-badge-danger"
                                : "ce-badge ce-badge-warning";

                            <tr>
                                <td style="color:var(--text-muted);font-size:.78rem">@idx</td>
                                <td>
                                    <div style="display:flex;align-items:center;gap:.65rem">
                                        <div class="ca-table-avatar" style="background:hsl(@(Math.Abs(sv?.ID?.GetHashCode() ?? 0) % 360),60%,55%)">
                                            @initials
                                        </div>
                                        <div>
                                            <div class="ca-table-name">@sv?.Ten</div>
                                            <div class="ca-table-id">@sv?.ID</div>
                                        </div>
                                    </div>
                                </td>
                                <td style="font-size:.82rem">
                                    <div>@sv?.Lop</div>
                                    <div style="font-size:.72rem;color:var(--text-muted)">@sv?.MaNghanh</div>
                                </td>
                                <td style="font-size:.82rem">@sv?.Email</td>
                                <td style="font-size:.82rem">@sv?.SoDienThoai</td>
                                <td style="font-size:.82rem;white-space:nowrap">@reg.NgayDangKy.ToString("dd/MM/yyyy HH:mm")</td>
                                <td><span class="@regBadge">@reg.TrangThai</span></td>
                                <td style="text-align:center">
                                    @if (reg.TrangThai != "Đã hủy")
                                    {
                                        using (Html.BeginForm("CancelRegistration","AdminEvents",new{area="Admin"},FormMethod.Post))
                                        {
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="maEvent"    value="@ev?.MaEvent"/>
                                            <input type="hidden" name="idSinhVien" value="@reg.IDSinhVien"/>
                                            <button type="submit" class="ce-btn ce-btn-sm ce-btn-danger"
                                                    onclick="return confirm('Hủy đăng ký của @sv?.Ten?')"
                                                    title="Hủy đăng ký">
                                                <span class="material-symbols-outlined">person_remove</span>
                                            </button>
                                        }
                                    }
                                    else
                                    {
                                        <span style="font-size:.72rem;color:var(--text-light)">—</span>
                                    }
                                </td>
                            </tr>
                            idx++;
                        }
                    }
                </tbody>
            </table>
        </div>

        <div class="ca-table-footer">
            <div class="ca-table-info">Trang @page / @totalPage · @totalReg đăng ký</div>
            <div style="display:flex;gap:.35rem;align-items:center">
                <a class="page-btn @(page<=1?"disabled":"")" href="@pageUrl(page-1)">
                    <span class="material-symbols-outlined" style="font-size:16px">chevron_left</span>
                </a>
                @for (int p = Math.Max(1,page-2); p <= Math.Min(totalPage,page+2); p++)
                {
                    <a class="page-btn @(p==page?"active":"")" href="@pageUrl(p)">@p</a>
                }
                <a class="page-btn @(page>=totalPage?"disabled":"")" href="@pageUrl(page+1)">
                    <span class="material-symbols-outlined" style="font-size:16px">chevron_right</span>
                </a>
            </div>
        </div>
    </div>
</div>
