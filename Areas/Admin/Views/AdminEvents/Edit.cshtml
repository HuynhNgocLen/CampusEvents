@model shcool_event_management.Models.EVENT
@{
    ViewBag.Title = "Chỉnh sửa sự kiện — CampusEvents Admin";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
    var danhMucList = ViewBag.DanhMucList as List<SelectListItem>;
    var vienList    = ViewBag.VienList    as List<SelectListItem>;
    var diaDiemText = ViewBag.DiaDiemText as string;
    double pct = Model != null && Model.SoLuongToiDa > 0
        ? Math.Round(Model.SoLuongDaDangKy * 100.0 / Model.SoLuongToiDa, 1) : 0;
}

@section styles {
<link href="@Url.Content("~/Content/campus-event-form.css?v=2")" rel="stylesheet" />
<link href="https://cdn.ckeditor.com/ckeditor5/41.1.0/classic/contents.css" rel="stylesheet"/>

}

<div class="ca-content">
    <div class="ca-breadcrumb">
        <a href="@Url.Action("Dashboard","AdminDashboard",new{area="Admin"})">Dashboard</a>
        <span class="material-symbols-outlined" style="font-size:14px">chevron_right</span>
        <a href="@Url.Action("Manage","AdminEvents",new{area="Admin"})">Quản lý bài đăng</a>
        <span class="material-symbols-outlined" style="font-size:14px">chevron_right</span>
        <span>Chỉnh sửa</span>
    </div>

    <div style="display:flex;align-items:center;gap:.75rem;margin-bottom:.35rem">
        <h1 class="ca-page-title" style="margin-bottom:0">Chỉnh sửa sự kiện</h1>
        @if (Model != null)
        {
            string badgeClass = Model.TrangThai == "Sắp diễn ra" ? "ce-badge ce-badge-info"
                : Model.TrangThai == "Đang diễn ra" ? "ce-badge ce-badge-success"
                : Model.TrangThai == "Đã hủy" ? "ce-badge ce-badge-danger"
                : "ce-badge ce-badge-default";
            <span class="@badgeClass">@Model.TrangThai</span>
        }
    </div>
    <p class="ca-page-sub">Cập nhật thông tin sự kiện. Các thay đổi sẽ có hiệu lực ngay sau khi lưu.</p>

    @Html.ValidationSummary(false, "", new { @class = "ce-alert ce-alert-error", style = "margin-bottom:1.25rem;" })

    @using (Html.BeginForm("Edit","AdminEvents",new{area="Admin",id=Model?.MaEvent},FormMethod.Post,new{enctype="multipart/form-data",id="editForm"}))
    {
        @Html.AntiForgeryToken()
        @Html.HiddenFor(m => m.MaEvent)
        @Html.HiddenFor(m => m.NgayTao)
        @Html.HiddenFor(m => m.SoLuongDaDangKy)
        @Html.HiddenFor(m => m.LuotXem)
        @Html.HiddenFor(m => m.AnhBia)
        @Html.HiddenFor(m => m.TrangThai)

        <div class="create-layout">
            @* LEFT *@
            <div>
                <div class="ca-card" style="margin-bottom:1.25rem">
                    <div class="ca-card__header">
                        <div class="ca-card__header-icon"><span class="material-symbols-outlined">info</span></div>
                        <div class="ca-card__title">Thông tin cơ bản</div>
                    </div>
                    <div class="ca-card__body">
                        <div class="ca-form-group">
                            <label class="ca-form-label">Tên sự kiện <span class="ca-required">*</span></label>
                            @Html.TextBoxFor(m => m.TenEvent, new { @class = "ca-form-input", maxlength = 200 })
                            @Html.ValidationMessageFor(m => m.TenEvent, "", new { @class = "ca-form-error" })
                        </div>
                        <div class="form-row">
                            <div class="ca-form-group">
                                <label class="ca-form-label">Danh mục <span class="ca-required">*</span></label>
                                @Html.DropDownListFor(m => m.MaDanhMuc, danhMucList ?? new List<SelectListItem>(), "— Chọn —", new { @class = "ca-form-select" })
                                @Html.ValidationMessageFor(m => m.MaDanhMuc, "", new { @class = "ca-form-error" })
                            </div>
                            <div class="ca-form-group">
                                <label class="ca-form-label">Viện tổ chức <span class="ca-required">*</span></label>
                                @Html.DropDownListFor(m => m.MaVien, vienList ?? new List<SelectListItem>(), "— Chọn —", new { @class = "ca-form-select" })
                                @Html.ValidationMessageFor(m => m.MaVien, "", new { @class = "ca-form-error" })
                            </div>
                        </div>
                        <div class="ca-form-group">
                            <label class="ca-form-label">Địa điểm <span class="ca-required">*</span></label>
                            <input type="text"
                                   name="diaDiemText"
                                   value="@diaDiemText"
                                   class="ca-form-input"
                                   maxlength="200"
                                   placeholder="VD: Hội trường A1 - Cơ sở 1" />
                            @Html.ValidationMessage("MaDiaDiem", "", new { @class = "ca-form-error" })
                        </div>
                        <div class="form-row">
                            <div class="ca-form-group">
                                <label class="ca-form-label">Ngày bắt đầu <span class="ca-required">*</span></label>
                                @Html.TextBoxFor(m => m.NgayBatDau, "{0:yyyy-MM-dd}", new { @class = "ca-form-input", type = "date" })
                                @Html.ValidationMessageFor(m => m.NgayBatDau, "", new { @class = "ca-form-error" })
                            </div>
                            <div class="ca-form-group">
                                <label class="ca-form-label">Hạn đăng ký</label>
                                @Html.TextBoxFor(m => m.NgayHetHanDangKy, "{0:yyyy-MM-dd}", new { @class = "ca-form-input", type = "date" })
                            </div>
                        </div>
                    </div>
                </div>

                <div class="ca-card" style="margin-bottom:1.25rem">
                    <div class="ca-card__header">
                        <div class="ca-card__header-icon"><span class="material-symbols-outlined">description</span></div>
                        <div class="ca-card__title">Nội dung</div>
                    </div>
                    <div class="ca-card__body">
                        <div class="ca-form-group">
                            <label class="ca-form-label">Mô tả sự kiện</label>
                            @Html.TextAreaFor(m => m.MoTa, new { id = "richContent" })
                        </div>
                    </div>
                </div>

                <div class="ca-card">
                    <div class="ca-card__header">
                        <div class="ca-card__header-icon"><span class="material-symbols-outlined">image</span></div>
                        <div class="ca-card__title">Ảnh bìa</div>
                    </div>
                    <div class="ca-card__body">
                        @if (!string.IsNullOrEmpty(Model?.AnhBia))
                        {
                            var coverSrc = Model.AnhBia.StartsWith("~")
                                ? Model.AnhBia
                                : (Model.AnhBia.StartsWith("/") ? "~" + Model.AnhBia : "~/Uploads/Events/" + Model.AnhBia);
                            <div class="preview-wrap" id="previewWrap" style="display:block">
                                <img id="previewImg" src="@Url.Content(coverSrc)" alt="Ảnh bìa"/>
                                <button type="button" class="preview-remove" id="previewRemove">
                                    <span class="material-symbols-outlined">close</span>
                                </button>
                            </div>
                            <p style="font-size:.73rem;color:var(--text-muted);margin-top:.4rem">Chọn ảnh mới để thay thế, hoặc giữ nguyên ảnh hiện tại.</p>
                        }
                        else
                        {
                            <div class="preview-wrap" id="previewWrap" style="display:none">
                                <img id="previewImg" src="" alt="Preview"/>
                                <button type="button" class="preview-remove" id="previewRemove">
                                    <span class="material-symbols-outlined">close</span>
                                </button>
                            </div>
                        }
                        <div class="upload-zone" id="uploadZone" style="@(!string.IsNullOrEmpty(Model?.AnhBia) ? "display:none" : "")"
                             onclick="document.getElementById('coverImageInput').click()">
                            <span class="material-symbols-outlined">cloud_upload</span>
                            <div style="font-size:.88rem;font-weight:700;margin-bottom:.25rem">Chọn ảnh mới</div>
                            <div style="font-size:.75rem;color:var(--text-muted)">JPG / PNG · Tối đa 5 MB</div>
                        </div>
                        <input type="file" id="coverImageInput" name="coverImage" accept="image/jpeg,image/png" style="display:none"/>
                    </div>
                </div>
            </div>

            @* RIGHT *@
            <div class="sticky-sidebar">
                <div class="ca-card" style="margin-bottom:1.25rem">
                    <div class="ca-card__header">
                        <div class="ca-card__header-icon" style="background:var(--success-light,#dcfce7);color:var(--success)">
                            <span class="material-symbols-outlined">save</span>
                        </div>
                        <div class="ca-card__title">Lưu thay đổi</div>
                    </div>
                    <div class="ca-card__body">
                        <button type="submit" name="btnAction" value="publish" class="publish-btn publish-btn-primary">
                            <span class="material-symbols-outlined">save</span>Lưu thay đổi
                        </button>
                        <a href="@Url.Action("Manage","AdminEvents",new{area="Admin"})" class="publish-btn publish-btn-outline js-cancel-event" style="text-align:center;display:flex">
                            <span class="material-symbols-outlined">arrow_back</span>Hủy
                        </a>
                    </div>
                </div>

                <div class="ca-card" style="margin-bottom:1.25rem">
                    <div class="ca-card__header">
                        <div class="ca-card__header-icon"><span class="material-symbols-outlined">tune</span></div>
                        <div class="ca-card__title">Cài đặt đăng ký</div>
                    </div>
                    <div class="ca-card__body">
                        <div class="ca-form-group">
                            <label class="ca-form-label">Số lượng tối đa <span class="ca-required">*</span></label>
                            @Html.TextBoxFor(m => m.SoLuongToiDa, new { @class = "ca-form-input", type = "number", min = 10 })
                            @Html.ValidationMessageFor(m => m.SoLuongToiDa, "", new { @class = "ca-form-error" })
                        </div>
                        <div class="ca-form-group">
                            <label class="ca-form-label">Điểm rèn luyện (DRL)</label>
                            @Html.TextBoxFor(m => m.DRL, new { @class = "ca-form-input", type = "number", min = 0, max = 20 })
                        </div>
                        <div style="display:flex;align-items:center;justify-content:space-between;padding:.65rem 0;border-top:1px solid var(--border)">
                            <div>
                                <div style="font-size:.84rem;font-weight:600">Ẩn sự kiện</div>
                                <div style="font-size:.72rem;color:var(--text-muted)">Không hiện trên trang chủ</div>
                            </div>
                            <label style="position:relative;display:inline-flex;align-items:center;cursor:pointer">
                                @Html.CheckBoxFor(m => m.IsHidden, new { id = "chkHidden", style = "opacity:0;width:0;height:0;position:absolute" })
                                <div id="switchTrack" style="width:40px;height:22px;background:var(--border);border-radius:999px;position:relative;transition:background .2s;cursor:pointer" onclick="toggleSwitch()">
                                    <div style="position:absolute;top:3px;left:3px;width:16px;height:16px;background:#fff;border-radius:50%;transition:transform .2s" id="switchThumb"></div>
                                </div>
                            </label>
                        </div>
                    </div>
                </div>

                <div class="ca-card">
                    <div class="ca-card__header">
                        <div class="ca-card__header-icon"><span class="material-symbols-outlined">analytics</span></div>
                        <div class="ca-card__title">Thống kê sự kiện</div>
                    </div>
                    <div class="ca-card__body" style="padding-top:.75rem">
                        <div class="stat-preview">
                            <div class="stat-preview__label">Đã đăng ký</div>
                            <div class="stat-preview__val" style="color:var(--primary)">@(Model != null ? Model.SoLuongDaDangKy : 0)</div>
                        </div>
                        <div class="stat-preview">
                            <div class="stat-preview__label">Tỷ lệ lấp đầy</div>
                            <div class="stat-preview__val" style="color:@(pct>=80?"var(--danger)":pct>=50?"var(--warning)":"var(--success)")">@pct%</div>
                        </div>
                        <div class="stat-preview">
                            <div class="stat-preview__label">Lượt xem</div>
                            <div class="stat-preview__val">@(Model != null ? Model.LuotXem : 0)</div>
                        </div>
                        @if (Model != null && Model.NgayTao != default(DateTime))
                        {
                            <div style="font-size:.72rem;color:var(--text-muted);margin-top:.25rem">
                                Tạo lúc: @Model.NgayTao.ToString("dd/MM/yyyy HH:mm")
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>
    }
</div>

@section scripts {
<script src="https://cdn.ckeditor.com/ckeditor5/41.1.0/classic/ckeditor.js"></script>
<script src="@Url.Content("~/Scripts/A-event-edit.js")"></script>
}
