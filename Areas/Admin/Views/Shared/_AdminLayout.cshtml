@{
    var adminQuyen = Session["AdminQuyen"] != null ? Convert.ToInt32(Session["AdminQuyen"]) : -1;
    var adminMaQTV = Session["AdminMaQTV"]?.ToString();
    var currentTenDN = User?.Identity?.Name;

    // Đồng bộ quyền theo DB để tránh lệch khi đổi quyền trực tiếp trong SQL.
    using (var db = new shcool_event_management.Models.school_event_managementEntities())
    {
        int? quyenFromDb = null;

        if (!string.IsNullOrEmpty(adminMaQTV))
        {
            quyenFromDb = db.QuanTriViens
                .Where(x => x.MaQTV == adminMaQTV)
                .Select(x => (int?)x.Quyen)
                .FirstOrDefault();
        }
        else if (!string.IsNullOrEmpty(currentTenDN))
        {
            var admin = db.QuanTriViens.FirstOrDefault(x => x.TenDN == currentTenDN);
            if (admin != null)
            {
                adminMaQTV = admin.MaQTV;
                quyenFromDb = admin.Quyen;
                Session["AdminMaQTV"] = adminMaQTV;
            }
        }

        if (quyenFromDb.HasValue)
        {
            adminQuyen = quyenFromDb.Value;
            Session["AdminQuyen"] = adminQuyen;
        }
    }

    var canViewStats = adminQuyen == 0;
    var canManageAdmins = adminQuyen == 0;
}
<!DOCTYPE html>
<html lang="vi" data-theme="light">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@(ViewBag.Title != null ? ViewBag.Title + " — " : "")CampusEvents Admin</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin="anonymous" />
    <link href="https://fonts.googleapis.com/css2?family=Lexend:wght@400;500;600;700;800&display=swap" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@20..48,100..700,0..1,-50..200&display=block" rel="stylesheet" />

    <!-- toastr -->
    <link href="https://cdnjs.cloudflare.com/ajax/libs/toastr.js/latest/toastr.min.css" rel="stylesheet" />

    <link href="@Url.Content("~/Content/campus-variables.css")"  rel="stylesheet" />
    <link href="@Url.Content("~/Content/campus-base.css")"       rel="stylesheet" />
    <link href="@Url.Content("~/Content/campus-navbar.css")"     rel="stylesheet" />
    <link href="@Url.Content("~/Content/campus-components.css")" rel="stylesheet" />
    <link href="@Url.Content("~/Content/campus-pages.css")"      rel="stylesheet" />
    <link href="@Url.Content("~/Content/campus-admin.css")"      rel="stylesheet" />
    <link href="@Url.Content("~/Content/campus-vibrant.css")"    rel="stylesheet" />

    @RenderSection("styles", required: false)

    <!-- Khởi tạo theme ngay để tránh flash -->
    <script>
        (function () {
            var saved = localStorage.getItem('ce-theme') || 'light';
            document.documentElement.setAttribute('data-theme', saved);
        })();
    </script>
</head>
<body>

    <div class="ca-sidebar-overlay" id="sidebarOverlay"></div>

    <div class="ca-shell" id="caShell">

        <aside class="ca-sidebar" id="adminSidebar" aria-label="Admin navigation">

            <a href="@Url.Action("Dashboard", "AdminDashboard", new { area = "Admin" })"
               class="ca-sidebar__brand" title="Trang chủ Admin">
                <div class="ca-sidebar__logo-icon">
                    <span class="material-symbols-outlined">event</span>
                </div>
                <div>
                    <div class="ca-sidebar__brand-name">CampusEvents</div>
                    <div class="ca-sidebar__brand-role">Academic Curator</div>
                </div>
            </a>

            <nav class="ca-sidebar__nav">

                <span class="ca-nav-section-label">Tổng quan</span>

                <a href="@Url.Action("Dashboard", "AdminDashboard", new { area = "Admin" })"
                   class="ca-nav-item @(ViewBag.ActiveMenu == "dashboard" ? "active" : "")"
                   data-label="Dashboard">
                    <span class="material-symbols-outlined">dashboard</span>
                    <span>Dashboard</span>
                </a>

                <a href="@Url.Action("Index", "AdminEvents", new { area = "Admin" })"
                   class="ca-nav-item @(ViewBag.ActiveMenu == "events" ? "active" : "")"
                   aria-current="@(ViewBag.ActiveMenu == "events" ? "page" : null)"
                   data-label="Sự kiện">
                    <span class="material-symbols-outlined">calendar_month</span>
                    <span>Sự kiện</span>
                </a>

                <span class="ca-nav-section-label">Nội dung</span>

                <a href="@Url.Action("Manage", "AdminEvents", new { area = "Admin" })"
                   class="ca-nav-item @(ViewBag.ActiveMenu == "manage" ? "active" : "")"
                   aria-current="@(ViewBag.ActiveMenu == "manage" ? "page" : null)"
                   data-label="Quản lí sự kiện">
                    <span class="material-symbols-outlined">event_note</span>
                    <span>Quản lí sự kiện</span>
                </a>

                <a href="@Url.Action("Create", "AdminEventPosts", new { area = "Admin" })"
                   class="ca-nav-item @(ViewBag.ActiveMenu == "event-post-create" ? "active" : "")"
                   aria-current="@(ViewBag.ActiveMenu == "event-post-create" ? "page" : null)"
                   data-label="Tạo bài đăng sự kiện">
                    <span class="material-symbols-outlined">add</span>
                    <span>Tạo bài đăng sự kiện</span>
                </a>

                @if (canViewStats)
                {
                    <span class="ca-nav-section-label">Báo cáo</span>

                    <a href="@Url.Action("AdminStats", "AdminStats", new { area = "Admin" })"
                       class="ca-nav-item @(ViewBag.ActiveMenu == "stats" ? "active" : "")"
                       aria-current="@(ViewBag.ActiveMenu == "stats" ? "page" : null)"
                       data-label="Thống kê">
                        <span class="material-symbols-outlined">bar_chart</span>
                        <span>Thống kê</span>
                    </a>
                }

                <span class="ca-nav-section-label">Hệ thống</span>

                <a href="@Url.Action("Index", "AdminSettings", new { area = "Admin" })"
                   class="ca-nav-item @(ViewBag.ActiveMenu == "settings" ? "active" : "")"
                   aria-current="@(ViewBag.ActiveMenu == "settings" ? "page" : null)"
                   data-label="Cài đặt">
                    <span class="material-symbols-outlined">settings</span>
                    <span>Cài đặt</span>
                </a>

                @if (canManageAdmins)
                {
                    <a href="@Url.Action("Index", "AdminAdministrators", new { area = "Admin" })"
                       class="ca-nav-item @(ViewBag.ActiveMenu == "admin-managers" ? "active" : "")"
                       aria-current="@(ViewBag.ActiveMenu == "admin-managers" ? "page" : null)"
                       data-label="Quản lí QTV">
                        <span class="material-symbols-outlined">manage_accounts</span>
                        <span>Quản lí QTV</span>
                    </a>
                }

                <div style="margin-top:auto; padding-top:1rem; border-top:1px solid var(--border)">
                    <a href="@Url.Action("Logout", "AdminAccount", new { area = "Admin" })"
                       class="ca-nav-item" style="color:var(--danger)"
                       data-label="Đăng xuất">
                        <span class="material-symbols-outlined">logout</span>
                        <span>Đăng xuất</span>
                    </a>
                </div>

            </nav>
        </aside>

        <div class="ca-main">

            <header class="ca-header" role="banner">

                <button class="ca-header__icon-btn ca-sidebar-toggle"
                        type="button" id="sidebarToggle"
                        aria-controls="adminSidebar"
                        aria-expanded="true"
                        aria-label="Toggle menu">
                    <span class="material-symbols-outlined">menu</span>
                </button>

                <div class="ca-header__search">
                    <span class="material-symbols-outlined ca-header__search-icon">search</span>
                    <input type="search"
                           id="adminGlobalSearch"
                           placeholder="@(ViewBag.SearchPlaceholder ?? "Tìm kiếm nội dung...")"
                           autocomplete="off" />
                </div>

                <div class="ca-header__actions">

                    <button class="ca-header__icon-btn"
                            id="themeToggleBtn"
                            data-action="toggle-theme"
                            title="Đổi giao diện sáng / tối">
                        <span class="material-symbols-outlined ce-theme-icon">light_mode</span>
                    </button>

                    <button class="ca-header__icon-btn d-none d-sm-flex" title="Thông báo"
                            onclick="ceOpenModal('modal-notif')">
                        <span class="material-symbols-outlined">notifications</span>
                        <span class="ce-notif-dot"></span>
                    </button>

                    <button class="ca-header__icon-btn" type="button" title="Trợ giúp"
                            onclick="ceOpenModal('modal-help')">
                        <span class="material-symbols-outlined">help</span>
                    </button>

                    <a href="@Url.Action("Profile", "AdminSettings", new { area = "Admin" })"
                       class="ca-header__profile" title="Hồ sơ Admin">
                        @if (!string.IsNullOrEmpty(ViewBag.AdminAvatar?.ToString()))
                        {
                            <div class="ca-header__avatar">
                                <img src="@ViewBag.AdminAvatar" alt="Avatar" />
                            </div>
                        }
                        else
                        {
                            <div class="ca-header__avatar-initials">AC</div>
                        }
                        <div>
                            <div class="ca-header__profile-name">@(ViewBag.AdminName ?? "Admin Campus")</div>
                            <div class="ca-header__profile-role">@(ViewBag.AdminRole ?? "Administrator")</div>
                        </div>
                    </a>

                </div>
            </header>

            @if (TempData["Success"] != null)
            {
                <div class="ce-toast-wrap">
                    <div class="ce-toast ce-toast-success" role="alert">
                        <span class="material-symbols-outlined">check_circle</span>
                        @TempData["Success"]
                    </div>
                </div>
            }
            @if (TempData["Error"] != null)
            {
                <div class="ce-toast-wrap">
                    <div class="ce-toast ce-toast-error" role="alert">
                        <span class="material-symbols-outlined">error</span>
                        @TempData["Error"]
                    </div>
                </div>
            }

            <main class="ca-content" id="mainContent" role="main">
                @RenderBody()
            </main>

            <footer class="ca-footer" role="contentinfo">
                <span>© 2024 Campus Management Suite &nbsp;·&nbsp; v2.1.0-STABLE</span>
                <div class="ca-footer__links">
                    <a href="#">System Status</a>
                    <a href="#">API Documentation</a>
                    <a href="#">Support</a>
                </div>
            </footer>

        </div>
    </div>


    <div class="ce-modal-overlay" id="modal-notif">
        <div class="ce-modal-box">
            <div class="ce-modal-header">
                <h5 class="d-flex align-items-center gap-2">
                    <span class="material-symbols-outlined" style="font-size:20px;color:var(--primary)">notifications</span>
                    Thông báo
                </h5>
                <button class="ce-modal-close" type="button" onclick="ceCloseModal('modal-notif')">
                    <span class="material-symbols-outlined">close</span>
                </button>
            </div>
            <div class="ce-modal-body pt-3">
                <div class="d-flex justify-content-end gap-2 mb-3">
                    <button id="ce-notif-read-all" type="button" class="ce-btn ce-btn-ghost ce-btn-sm">
                        <span class="material-symbols-outlined">drafts</span>
                        Đọc tất cả
                    </button>
                    <button id="ce-notif-clear-all" type="button" class="ce-btn ce-btn-danger ce-btn-sm">
                        <span class="material-symbols-outlined">delete</span>
                        Xóa tất cả
                    </button>
                </div>
                <div id="ce-notif-list" class="d-flex flex-column gap-2"></div>
            </div>
            <div class="ce-modal-footer">
                <button type="button" class="ce-btn ce-btn-primary" onclick="ceCloseModal('modal-notif')">Đóng</button>
            </div>
        </div>
    </div>

    <div class="ce-modal-overlay" id="modal-help">
        <div class="ce-modal-box">
            <div class="ce-modal-header">
                <h5 class="d-flex align-items-center gap-2">
                    <span class="material-symbols-outlined" style="font-size:20px;color:var(--primary)">help</span>
                    Trợ giúp nhanh
                </h5>
                <button class="ce-modal-close" type="button" onclick="ceCloseModal('modal-help')">
                    <span class="material-symbols-outlined">close</span>
                </button>
            </div>
            <div class="ce-modal-body">
                <div class="d-flex flex-column gap-2">
                    <div class="border rounded-3 p-3">
                        <div class="fw-semibold mb-1">Tạo sự kiện mới</div>
                        <div class="text-muted small">Vào mục Tạo bài đăng sự kiện để thêm sự kiện và lịch trình.</div>
                    </div>
                    <div class="border rounded-3 p-3">
                        <div class="fw-semibold mb-1">Quản lí đăng ký</div>
                        <div class="text-muted small">Mở Quản lí sự kiện và chọn chi tiết để duyệt danh sách đăng ký.</div>
                    </div>
                    <div class="border rounded-3 p-3">
                        <div class="fw-semibold mb-1">Liên hệ hỗ trợ</div>
                        <div class="text-muted small">Nếu gặp lỗi hệ thống, vui lòng liên hệ quản trị cấp cao để kiểm tra quyền.</div>
                    </div>
                </div>
            </div>
            <div class="ce-modal-footer">
                <button type="button" class="ce-btn ce-btn-primary" onclick="ceCloseModal('modal-help')">Đã hiểu</button>
            </div>
        </div>
    </div>

    <!-- Scripts -->
    <script src="https://cdn.jsdelivr.net/npm/jquery@3.7.1/dist/jquery.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/toastr.js/latest/toastr.min.js"></script>
    <script src="@Url.Content("~/Scripts/campus-app.js")"></script>

    @RenderSection("scripts", required: false)
</body>
</html>
