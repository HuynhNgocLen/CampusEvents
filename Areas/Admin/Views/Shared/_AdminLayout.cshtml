<!DOCTYPE html>
<html lang="vi" data-theme="light">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@(ViewBag.Title != null ? ViewBag.Title + " — " : "")CampusEvents Admin</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin="anonymous" />
    <link href="https://fonts.googleapis.com/css2?family=Lexend:wght@400;500;600;700;800&display=swap" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@20..48,100..700,0..1,-50..200&display=block" rel="stylesheet" />

    <!-- toastr -->
    <link href="https://cdnjs.cloudflare.com/ajax/libs/toastr.js/latest/toastr.min.css" rel="stylesheet" />

    <link href="@Url.Content("~/Content/campus-variables.css")"  rel="stylesheet" />
    <link href="@Url.Content("~/Content/campus-base.css")"       rel="stylesheet" />
    <link href="@Url.Content("~/Content/campus-navbar.css")"     rel="stylesheet" />
    <link href="@Url.Content("~/Content/campus-components.css")" rel="stylesheet" />
    <link href="@Url.Content("~/Content/campus-pages.css")"      rel="stylesheet" />
    <link href="@Url.Content("~/Content/campus-admin.css")"      rel="stylesheet" />

    @RenderSection("styles", required: false)

    <!-- Khởi tạo theme ngay để tránh flash -->
    <script>
        (function () {
            var saved = localStorage.getItem('ce-theme') || 'light';
            document.documentElement.setAttribute('data-theme', saved);
        })();
    </script>
</head>
<body>

    @Html.AntiForgeryToken()

    <div class="ca-sidebar-overlay" id="sidebarOverlay"></div>

    <div class="ca-shell" id="caShell">

        <aside class="ca-sidebar" id="adminSidebar" aria-label="Admin navigation">

            <a href="@Url.Action("Index", "AdminDashboard", new { area = "Admin" })"
               class="ca-sidebar__brand" title="Trang chủ Admin">
                <div class="ca-sidebar__logo-icon">
                    <span class="material-symbols-outlined">event</span>
                </div>
                <div>
                    <div class="ca-sidebar__brand-name">CampusEvents</div>
                    <div class="ca-sidebar__brand-role">Academic Curator</div>
                </div>
            </a>

            <nav class="ca-sidebar__nav">

                <span class="ca-nav-section-label">Tổng quan</span>

                <a href="@Url.Action("Dashboard", "AdminDashboard", new { area = "Admin" })"
                   class="ca-nav-item @(ViewBag.ActiveMenu == "dashboard" ? "active" : "")"
                   data-label="Dashboard">
                    <span class="material-symbols-outlined">dashboard</span>
                    <span>Dashboard</span>
                </a>

                <a href="@Url.Action("Index", "AdminEvents", new { area = "Admin" })"
                   class="ca-nav-item @(ViewBag.ActiveMenu == "events" ? "active" : "")"
                   aria-current="@(ViewBag.ActiveMenu == "events" ? "page" : null)"
                   data-label="Sự kiện">
                    <span class="material-symbols-outlined">calendar_month</span>
                    <span>Sự kiện</span>
                </a>

                <span class="ca-nav-section-label">Nội dung</span>

                <a href="@Url.Action("Create", "AdminEvents", new { area = "Admin" })"
                   class="ca-nav-item @(ViewBag.ActiveMenu == "create" ? "active" : "")"
                   aria-current="@(ViewBag.ActiveMenu == "create" ? "page" : null)"
                   data-label="Tạo bài đăng">
                    <span class="material-symbols-outlined">add_circle</span>
                    <span>Tạo bài đăng</span>
                </a>

                <span class="ca-nav-section-label">Báo cáo</span>

                <a href="@Url.Action("AdminStats", "AdminStats", new { area = "Admin" })"
                   class="ca-nav-item @(ViewBag.ActiveMenu == "stats" ? "active" : "")"
                   aria-current="@(ViewBag.ActiveMenu == "stats" ? "page" : null)"
                   data-label="Thống kê">
                    <span class="material-symbols-outlined">bar_chart</span>
                    <span>Thống kê</span>
                </a>

                <span class="ca-nav-section-label">Hệ thống</span>

                <a href="@Url.Action("Index", "AdminSettings", new { area = "Admin" })"
                   class="ca-nav-item @(ViewBag.ActiveMenu == "settings" ? "active" : "")"
                   aria-current="@(ViewBag.ActiveMenu == "settings" ? "page" : null)"
                   data-label="Cài đặt">
                    <span class="material-symbols-outlined">settings</span>
                    <span>Cài đặt</span>
                </a>

                <div style="margin-top:auto; padding-top:1rem; border-top:1px solid var(--border)">
                    <a href="@Url.Action("Logout", "AdminAuth", new { area = "Admin" })"
                       class="ca-nav-item" style="color:var(--danger)"
                       data-label="Đăng xuất">
                        <span class="material-symbols-outlined">logout</span>
                        <span>Đăng xuất</span>
                    </a>
                </div>

            </nav>
        </aside>

        <div class="ca-main">

            <header class="ca-header" role="banner">

                <button class="ca-header__icon-btn ca-sidebar-toggle"
                        type="button" id="sidebarToggle"
                        aria-controls="adminSidebar"
                        aria-expanded="true"
                        aria-label="Toggle menu">
                    <span class="material-symbols-outlined">menu</span>
                </button>

                <div class="ca-header__search">
                    <span class="material-symbols-outlined ca-header__search-icon">search</span>
                    <input type="search"
                           id="adminGlobalSearch"
                           placeholder="@(ViewBag.SearchPlaceholder ?? "Tìm kiếm nội dung...")"
                           autocomplete="off" />
                </div>

                <div class="ca-header__actions">

                    <button class="ca-header__icon-btn"
                            id="themeToggleBtn"
                            data-action="toggle-theme"
                            title="Đổi giao diện sáng / tối">
                        <span class="material-symbols-outlined ce-theme-icon">light_mode</span>
                    </button>

                    <button class="ca-header__icon-btn d-none d-sm-flex" title="Thông báo"
                            onclick="ceOpenModal('modal-notif')">
                        <span class="material-symbols-outlined">notifications</span>
                        <span class="ce-notif-dot"></span>
                    </button>

                    <button class="ca-header__icon-btn" type="button" title="Trợ giúp">
                        <span class="material-symbols-outlined">help</span>
                    </button>

                    <a href="@Url.Action("Profile", "AdminSettings", new { area = "Admin" })"
                       class="ca-header__profile" title="Hồ sơ Admin">
                        @if (!string.IsNullOrEmpty(ViewBag.AdminAvatar?.ToString()))
                        {
                            <div class="ca-header__avatar">
                                <img src="@ViewBag.AdminAvatar" alt="Avatar" />
                            </div>
                        }
                        else
                        {
                            <div class="ca-header__avatar-initials">AC</div>
                        }
                        <div>
                            <div class="ca-header__profile-name">@(ViewBag.AdminName ?? "Admin Campus")</div>
                            <div class="ca-header__profile-role">@(ViewBag.AdminRole ?? "Administrator")</div>
                        </div>
                    </a>

                </div>
            </header>

            @if (TempData["Success"] != null)
            {
                <div class="ce-toast-wrap">
                    <div class="ce-toast ce-toast-success" role="alert">
                        <span class="material-symbols-outlined">check_circle</span>
                        @TempData["Success"]
                    </div>
                </div>
            }
            @if (TempData["Error"] != null)
            {
                <div class="ce-toast-wrap">
                    <div class="ce-toast ce-toast-error" role="alert">
                        <span class="material-symbols-outlined">error</span>
                        @TempData["Error"]
                    </div>
                </div>
            }

            <main class="ca-content" id="mainContent" role="main">
                @RenderBody()
            </main>

            <footer class="ca-footer" role="contentinfo">
                <span>© 2024 Campus Management Suite &nbsp;·&nbsp; v2.1.0-STABLE</span>
                <div class="ca-footer__links">
                    <a href="#">System Status</a>
                    <a href="#">API Documentation</a>
                    <a href="#">Support</a>
                </div>
            </footer>

        </div>
    </div>


    <!-- Scripts -->
    <script src="https://cdn.jsdelivr.net/npm/jquery@3.7.1/dist/jquery.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/toastr.js/latest/toastr.min.js"></script>
    <script src="@Url.Content("~/Scripts/campus-app.js")"></script>

    @RenderSection("scripts", required: false)
</body>
</html>
