@{
    ViewBag.Title = "Đăng nhập quản trị";
    Layout = null;
}
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewBag.Title — CampusEvents Admin</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Lexend:wght@400;500;600;700;800&display=swap" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@20..48,100..700,0..1,-50..200" rel="stylesheet" />
    <link href="~/Content/campus-variables.css" rel="stylesheet" />
    <link href="~/Content/campus-base.css" rel="stylesheet" />
    <link href="~/Content/campus-components.css" rel="stylesheet" />
    <link href="~/Content/campus-pages.css" rel="stylesheet" />
    <link href="~/Content/campus-vibrant.css" rel="stylesheet" />
</head>
<body>
    <div class="ce-auth-page">
        <div class="ce-auth-panel" style="max-width:420px;margin:2rem auto;padding:2rem 1.75rem">
            <div style="display:flex;align-items:center;gap:.65rem;margin-bottom:1.25rem">
                <div style="width:42px;height:42px;background:var(--primary);border-radius:10px;display:flex;align-items:center;justify-content:center;color:#fff">
                    <span class="material-symbols-outlined" style="font-size:24px">admin_panel_settings</span>
                </div>
                <div>
                    <div style="font-weight:800;font-size:1.05rem">CampusEvents Admin</div>
                    <div style="font-size:.72rem;color:var(--text-muted)">Phiên làm việc tối đa 1 giờ</div>
                </div>
            </div>
            <div class="ce-auth-title" style="font-size:1.15rem">Đăng nhập quản trị</div>
            <div class="ce-auth-sub" style="margin-bottom:1.25rem">Tên đăng nhập không dấu, không khoảng trắng</div>

            @using (Html.BeginForm("Login", "AdminAccount", new { area = "Admin" }, FormMethod.Post, new { @class = "mb-0" }))
            {
                @Html.AntiForgeryToken()
                <input type="hidden" name="returnUrl" value="@ViewBag.ReturnUrl" />
                if (!ViewData.ModelState.IsValid)
                {
                    <div class="alert alert-danger" style="font-size:0.85rem;padding:0.75rem;border-radius:8px;margin-bottom:1rem;">
                        @Html.ValidationSummary(true, "", new { @class = "mb-0" })
                    </div>
                }
                <div class="mb-3">
                    <label class="ce-form-label">Tên đăng nhập</label>
                    <div class="ce-input-icon">
                        <span class="material-symbols-outlined icon">person</span>
                        <input class="ce-form-control" name="tenDN" type="text" autocomplete="username" placeholder="vd: tdmu" required />
                    </div>
                </div>
                <div class="mb-3">
                    <label class="ce-form-label">Mật khẩu</label>
                    <div class="ce-input-icon">
                        <span class="material-symbols-outlined icon">lock</span>
                        <input class="ce-form-control" name="matKhau" type="password" autocomplete="current-password" placeholder="••••••••" required />
                    </div>
                </div>
                <button type="submit" class="ce-btn ce-btn-primary ce-btn-block ce-btn-lg mb-3">
                    <span class="material-symbols-outlined">login</span> Đăng nhập
                </button>
            }
            <a href="@Url.Action("Login", "Account", new { area = "" })" class="ce-btn ce-btn-ghost ce-btn-block" style="text-decoration:none;justify-content:center;display:flex;align-items:center;gap:.4rem">
                <span class="material-symbols-outlined" style="font-size:18px">arrow_back</span> Về đăng nhập sinh viên
            </a>
        </div>
    </div>
</body>
</html>
