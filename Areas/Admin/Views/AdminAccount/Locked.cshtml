@{
    ViewBag.Title = "Tài khoản bị khóa";
    Layout = null;
}
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewBag.Title — CampusEvents Admin</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Lexend:wght@400;500;600;700;800&display=swap" rel="stylesheet" />
    <link href="~/Content/app/campus-variables.css" rel="stylesheet" />
    <link href="~/Content/app/campus-base.css" rel="stylesheet" />
    <link href="~/Content/app/campus-components.css" rel="stylesheet" />
    <link href="~/Content/app/campus-pages.css" rel="stylesheet" />
    <link href="~/Content/app/campus-vibrant.css" rel="stylesheet" />
</head>
<body>
    <div class="ce-auth-page">
        <div class="ce-auth-panel" style="max-width:460px;margin:2rem auto;padding:2rem 1.75rem">
            <div class="alert alert-danger mb-3">
                Tài khoản của bạn đã bị khóa.
            </div>
            <p class="text-muted mb-4">Vui lòng liên hệ quản trị viên cấp cao để được hỗ trợ mở khóa.</p>
            <a class="ce-btn ce-btn-danger ce-btn-block ce-btn-lg"
               href="@Url.Action("Logout", "AdminAccount", new { area = "Admin" })">
                Đăng xuất
            </a>
        </div>
    </div>
</body>
</html>
