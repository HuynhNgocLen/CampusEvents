@model List<shcool_event_management.Models.DangKySuKien>

<div id="tab-saved" class="ce-tab-pane">
    @if (Model == null || !Model.Any())
    {
        <div class="ce-empty text-center py-5">
            <span class="material-symbols-outlined text-muted" style="font-size: 56px; opacity: 0.5;">bookmark_border</span>
            <h5 class="ce-empty__title mt-3 fw-bold" style="color: var(--text);">Chưa có sự kiện nào được lưu</h5>
            <p class="small mb-0" style="color: var(--text);">Lưu lại những sự kiện bạn quan tâm để dễ dàng xem và đăng ký sau nhé.</p>
        </div>
    }
    else
    {
        <div class="d-flex flex-column gap-3">
            @foreach (var dk in Model)
            {
                var ev = dk.EVENT;
                var ngayHienTai = DateTime.Now;
                bool daHetHan = ev.NgayHetHanDangKy.HasValue && ev.NgayHetHanDangKy.Value.Date < ngayHienTai.Date;
                var conLai = (ev.SoLuongToiDa) - (ev.SoLuongDaDangKy);
                bool hetCho = conLai <= 0;

                <div class="ce-card p-3 p-md-4 ce-hover-card saved-card filter-card-item" id="saved-item-@ev.MaEvent" data-date="@ev.NgayBatDau.ToString("yyyy-MM-dd")">
                    <div class="d-flex gap-3 align-items-start">

                        <div class="ce-icon-box rounded-3 overflow-hidden flex-shrink-0"
                             style="width: 56px; height: 56px; background: var(--surface-2);">
                            <div class="w-100 h-100 d-flex align-items-center justify-content-center" style="color: var(--primary);">
                                <span class="material-symbols-outlined" style="font-size: 28px;">bookmark</span>
                            </div>
                        </div>

                        <div class="flex-grow-1 min-w-0">
                            <h6 class="fw-bold mb-2 text-truncate" style="font-size: 1.1rem; color: var(--text);">@ev.TenEvent</h6>

                            <div class="d-flex flex-wrap align-items-center gap-2 small mb-3" style="color: var(--text-muted);">
                                <span class="material-symbols-outlined" style="font-size: 16px; color: var(--primary);">calendar_month</span>
                                <span>Bắt đầu: @ev.NgayBatDau.ToString("dd/MM/yyyy HH:mm")</span>
                            </div>

                            <div class="d-flex flex-wrap justify-content-between align-items-center gap-2 mt-3 pt-3" style="border-top: 1px solid var(--border);">

                                <button class="ce-btn ce-btn-sm ce-btn-ghost flex-grow-1 flex-sm-grow-0 justify-content-center"
                                        style="color: var(--text-muted);"
                                        onclick="fastRemoveFavorite(this, @ev.MaEvent)">
                                    <span class="material-symbols-outlined">bookmark_remove</span> Bỏ lưu
                                </button>

                                <div class="flex-grow-1 flex-sm-grow-0">
                                    @if (daHetHan)
                                    {
                                        <button class="ce-btn ce-btn-sm w-100 justify-content-center" disabled
                                                style="background: var(--surface-2); color: var(--text-muted); border: 1px solid var(--border); cursor: not-allowed; opacity: 0.7;">
                                            <span class="material-symbols-outlined">event_busy</span> Hết hạn
                                        </button>
                                    }
                                    else if (hetCho)
                                    {
                                        <button class="ce-btn ce-btn-sm w-100 justify-content-center" disabled
                                                style="background: rgba(239, 68, 68, 0.1); color: var(--danger); border: 1px solid rgba(239, 68, 68, 0.2); cursor: not-allowed;">
                                            <span class="material-symbols-outlined">block</span> Hết chỗ
                                        </button>
                                    }
                                    else
                                    {
                                        <a href="@Url.Action("EventDetail", "Users", new { id = ev.MaEvent })" class="ce-btn ce-btn-sm ce-btn-primary w-100 justify-content-center">
                                            <span class="material-symbols-outlined">how_to_reg</span> Đăng ký ngay
                                        </a>
                                    }
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>