@model List<shcool_event_management.Models.DangKySuKien>

<div class="ce-tab-pane" id="tab-cancelled">
    @if (Model == null || !Model.Any())
    {
        <div class="ce-empty text-center py-5">
            <span class="material-symbols-outlined text-muted" style="font-size: 56px; opacity: 0.5;">layers_clear</span>
            <h5 class="ce-empty__title mt-3 fw-bold" style="color: var(--text);">Chưa có sự kiện bị hủy</h5>
            <p class="small mb-0" style="color: var(--text);">Tuyệt vời! Bạn chưa hủy đăng ký sự kiện nào.</p>
        </div>
    }
    else
    {
        <div class="d-flex flex-column gap-3 ce-scrollable-list">
            @foreach (var dk in Model)
            {
                var ev = dk.EVENT;

                <div class="ce-card p-3 p-md-4 ce-hover-card cancelled-card filter-card-item" data-date="@ev.NgayBatDau.ToString("yyyy-MM-dd")">
                    <div class="d-flex gap-3 align-items-start">

                        <div class="ce-icon-box rounded-3 d-flex align-items-center justify-content-center flex-shrink-0"
                             style="width: 48px; height: 48px; background: rgba(239, 68, 68, 0.12); color: var(--danger);">
                            <span class="material-symbols-outlined">event_busy</span>
                        </div>

                        <div class="flex-grow-1 min-w-0">

                            <div class="d-flex flex-wrap justify-content-between align-items-start gap-2 mb-2">
                                <h6 class="fw-bold mb-0 text-truncate flex-grow-1"
                                    style="font-size: 1.1rem; text-decoration: line-through; color: var(--text-muted); min-width: 150px;">
                                    @ev.TenEvent
                                </h6>
                                <span class="ce-badge ce-badge-danger flex-shrink-0" style="opacity: 0.85;">Đã hủy</span>
                            </div>

                            <div class="d-flex flex-wrap gap-3 small mb-3" style="color: var(--text-muted);">
                                <div class="d-flex align-items-center gap-1">
                                    <span class="material-symbols-outlined" style="font-size: 16px; color: var(--primary);">calendar_month</span>
                                    <span>Dự kiến: @ev.NgayBatDau.ToString("dd/MM/yyyy")</span>
                                </div>
                                <div class="d-flex align-items-center gap-1">
                                    <span class="material-symbols-outlined" style="font-size: 16px; color: var(--danger);">schedule</span>
                                    <span>Hủy lúc: @dk.NgayDangKy.ToString("dd/MM/yyyy HH:mm")</span>
                                </div>
                            </div>

                            <div class="d-flex flex-wrap justify-content-end gap-2 mt-3 pt-3" style="border-top: 1px solid var(--border);">
                                <a href="@Url.Action("EventDetail","Users", new { id = ev.MaEvent })"
                                   class="ce-btn ce-btn-ghost ce-btn-sm flex-grow-1 flex-sm-grow-0 justify-content-center"
                                   style="color: var(--text-muted);">
                                    <span class="material-symbols-outlined">info</span> Xem lại chi tiết
                                </a>
                            </div>

                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>