@{
    Layout = "~/Views/Shared/_LayoutUsers.cshtml";
    ViewBag.ActivePage = "settings";

    var receiveInApp = (bool)(ViewBag.ReceiveInApp ?? true);
    var receiveEmail = (bool)(ViewBag.ReceiveEmail ?? true);
    var receiveReminder = (bool)(ViewBag.ReceiveReminder ?? true);
}

<div class="container py-4">
    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success">@TempData["Success"]</div>
    }

    <div class="ce-card p-4 mb-4">
        <div class="d-flex align-items-center gap-2 mb-2">
            <span class="material-symbols-outlined" style="color: var(--primary);">settings</span>
            <h4 class="mb-0">Cài đặt tài khoản</h4>
        </div>
        <p class="text-muted mb-0">Quản lý tùy chọn thông báo cho tài khoản sinh viên của bạn.</p>
    </div>

    <div class="ce-card p-4">
        @using (Html.BeginForm("UpdateSettings", "Home", FormMethod.Post))
        {
            @Html.AntiForgeryToken()

            <div class="form-check form-switch mb-3">
                <input class="form-check-input" type="checkbox" id="receiveInApp" name="receiveInApp" value="true" @(receiveInApp ? "checked" : "") />
                <label class="form-check-label" for="receiveInApp">Nhận thông báo trong ứng dụng</label>
            </div>

            <div class="form-check form-switch mb-3">
                <input class="form-check-input" type="checkbox" id="receiveEmail" name="receiveEmail" value="true" @(receiveEmail ? "checked" : "") />
                <label class="form-check-label" for="receiveEmail">Nhận thông báo qua email</label>
            </div>

            <div class="form-check form-switch mb-4">
                <input class="form-check-input" type="checkbox" id="receiveReminder" name="receiveReminder" value="true" @(receiveReminder ? "checked" : "") />
                <label class="form-check-label" for="receiveReminder">Nhắc lịch trước sự kiện</label>
            </div>

            <div class="d-flex gap-2">
                <button type="submit" class="ce-btn ce-btn-primary">
                    <span class="material-symbols-outlined">save</span>
                    Lưu cài đặt
                </button>
                <a class="ce-btn ce-btn-ghost" href="@Url.Action("Profile", "Home")">
                    <span class="material-symbols-outlined">person</span>
                    Về hồ sơ
                </a>
            </div>
        }
    </div>
</div>
