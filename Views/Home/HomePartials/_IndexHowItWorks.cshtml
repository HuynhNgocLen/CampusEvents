@* ── THAM GIA CHỈ VỚI 4 BƯỚC ── *@
<section class="ce-index-section" style="background:var(--surface-2)">
    <div class="container py-5">
        <div class="text-center mb-5">
            <h2 style="font-size:clamp(1.5rem,4vw,2.2rem);font-weight:800;color:var(--text)">
                Tham gia sự kiện chỉ với <span style="color:#38bdf8">4 bước</span>
            </h2>
            <p style="color:var(--text-muted);font-size:.9rem;margin-top:.5rem">
                Trải nghiệm liền mạch trên cả mobile và desktop.
            </p>
        </div>

        <div class="row g-3">
            @{
                var steps = new[]
                {
                    new { Num="1", Icon="search",            Title="Tìm sự kiện",    Desc="Lọc theo viện, danh mục, thời gian — tìm sự kiện phù hợp trong vài giây." },
                    new { Num="2", Icon="calendar_add_on",   Title="Đăng ký nhanh", Desc="Một cú click để giữ chỗ. Nhận xác nhận tức thì qua thông báo." },
                    new { Num="3", Icon="qr_code_2",         Title="Check-in QR",   Desc="Mã QR cá nhân giúp bạn check-in tại sự kiện chỉ trong 1 giây." },
                    new { Num="4", Icon="notifications",     Title="Nhắc lịch",     Desc="Đồng bộ lịch & nhận nhắc nhở để không bỏ lỡ bất kỳ sự kiện nào." },
                };
            }
            @foreach (var step in steps)
            {
                <div class="col-12 col-sm-6">
                    <div class="ce-step-card ce-reveal">
                        <div class="ce-step-card__num">@step.Num</div>
                        <div class="ce-step-card__icon">
                            <span class="material-symbols-outlined">@step.Icon</span>
                        </div>
                        <div class="ce-step-card__title">@step.Title</div>
                        <p class="ce-step-card__desc">@step.Desc</p>
                    </div>
                </div>
            }
        </div>
    </div>
</section>
