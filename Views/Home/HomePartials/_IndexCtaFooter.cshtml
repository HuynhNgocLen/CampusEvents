@* ── CTA BANNER ── *@
<section class="ce-cta-banner">
    <div class="container">
        <div class="ce-cta-inner">
            <div class="ce-cta-badge">
                <span class="material-symbols-outlined" style="font-size:14px">smartphone</span>
                Mobile · Desktop · PWA
            </div>
            <h2 class="ce-cta-title">Sẵn sàng tham gia sự kiện đầu tiên?</h2>
            <p class="ce-cta-sub">
                Tạo tài khoản miễn phí với mã sinh viên và bắt đầu khám phá hàng trăm sự kiện ngay hôm nay.
            </p>
            <div class="ce-cta-btns">
                <a href="@Url.Action("Login","Account")" class="ce-btn ce-btn-dark ce-btn-lg">
                    Đăng ký ngay →
                </a>
                <a href="#" class="ce-btn ce-btn-outline-light ce-btn-lg">Xem demo</a>
            </div>
        </div>
    </div>
</section>

