@model shcool_event_management.Models.SinhVien
@using shcool_event_management.Models
@{
    Layout = "~/Views/Shared/_LayoutUsers.cshtml";
    ViewBag.ActivePage = "profile";

    var drl = (int)(ViewBag.DRL ?? 0);
    var hocKy = (int)(ViewBag.HocKy ?? 1);
    var nam = (int)(ViewBag.Nam ?? DateTime.Now.Year);
    var tongHT = (int)(ViewBag.TongHoanThanh ?? 0);
    var isMe = ViewBag.IsCurrentUser == true;
    var thanhTich = ViewBag.ThanhTich as List<string> ?? new List<string>();
    var daThamDu = ViewBag.DaThamDu as List<DangKySuKien> ?? new List<DangKySuKien>();
    var suKienNam = ViewBag.SuKienTrongNam as List<EVENT> ?? new List<EVENT>();
    var currentYear = (int)(ViewBag.CurrentYear ?? DateTime.Now.Year);

    var words = (Model.Ten ?? "SV").Trim().Split(new[] { ' ' }, StringSplitOptions.RemoveEmptyEntries);
    var initials = words.Length >= 2
        ? (words[words.Length - 2].Substring(0, 1) + words[words.Length - 1].Substring(0, 1)).ToUpper()
        : words[0].Substring(0, 1).ToUpper();

    string drlCls = drl >= 15 ? "pf-drl--green" : (drl >= 8 ? "pf-drl--blue" : "pf-drl--gray");
}

@* FIX TS2683: tách hàm đóng alert ra script riêng, không dùng this trong onclick *@
<script>
document.addEventListener('DOMContentLoaded', function() {
    document.querySelectorAll('.pf-alert__close').forEach(function(btn) {
        btn.addEventListener('click', function() {
            var alert = btn.closest('.pf-alert');
            if (alert) alert.remove();
        });
    });
});
</script>

@if (TempData["Success"] != null)
{
    <div class="pf-alert pf-alert--success">
        <span class="material-symbols-outlined">check_circle</span>
        @TempData["Success"]
        @* FIX line 30: dùng closeAlert(this) thay vì this.parentElement.remove() *@
        <button class="pf-alert__close">
            <span class="material-symbols-outlined">close</span>
        </button>
    </div>
}
@if (TempData["Error"] != null)
{
    <div class="pf-alert pf-alert--error">
        <span class="material-symbols-outlined">error</span>
        @TempData["Error"]
        @* FIX line 40: dùng closeAlert(this) thay vì this.parentElement.remove() *@
        <button class="pf-alert__close">
            <span class="material-symbols-outlined">close</span>
        </button>
    </div>
}

<div class="container py-4">
    <div class="row g-4">

        <div class="col-lg-4">

            <div class="ce-card p-4 text-center mb-4 pf-avatar-card">
                <div class="pf-avatar mx-auto mb-3">@initials</div>

                <h4 class="pf-name">@Model.Ten</h4>
                <p class="pf-sub">
                    <span class="material-symbols-outlined pf-sub__icon">badge</span>@Model.ID
                    @if (!string.IsNullOrEmpty(Model.Lop))
                    {
                        <span class="pf-dot">·</span>
                        <span class="material-symbols-outlined pf-sub__icon">school</span>@Model.Lop
                    }
                </p>
                @if (!string.IsNullOrEmpty(Model.MaNghanh))
                {
                    <p class="pf-dept">@Model.MaNghanh @(Model.Vien != null ? "– " + Model.Vien.TenVien : "")</p>
                }

                <div class="d-flex justify-content-center flex-wrap gap-2 mt-3">
                    <span class="ce-badge ce-badge-success">
                        <span class="material-symbols-outlined" style="font-size:14px">verified</span>
                        Sinh viên
                    </span>
                    <span class="ce-badge ce-badge-primary">
                        <span class="material-symbols-outlined" style="font-size:14px">military_tech</span>
                        HK @hocKy / @nam – @(nam+1)
                    </span>
                </div>

                @* DRL ring *@
                <div class="pf-drl-wrap mt-4">
                    <div class="pf-drl @drlCls">
                        <div class="pf-drl__val">@drl</div>
                        <div class="pf-drl__lbl">điểm ĐRL</div>
                    </div>
                    <div class="pf-drl-meta">
                        <div class="pf-drl-meta__label">ĐRL Học kỳ @hocKy</div>
                        <div class="pf-drl-meta__sub">Năm học @nam – @(nam+1)</div>
                    </div>
                </div>

                @* Thống kê nhỏ *@
                <div class="pf-stats mt-4">
                    <div class="pf-stats__item">
                        <div class="pf-stats__val">@tongHT</div>
                        <div class="pf-stats__lbl">Đã hoàn thành</div>
                    </div>
                    <div class="pf-stats__sep"></div>
                    <div class="pf-stats__item">
                        <div class="pf-stats__val">@suKienNam.Count</div>
                        <div class="pf-stats__lbl">Đã tổ chức</div>
                    </div>
                    <div class="pf-stats__sep"></div>
                    <div class="pf-stats__item">
                        <div class="pf-stats__val">@thanhTich.Count</div>
                        <div class="pf-stats__lbl">Thành tích</div>
                    </div>
                </div>
            </div>

            @* ── Thành tích ── *@
            <div class="ce-card p-4 mb-4">
                <div class="pf-section-hd">
                    <span class="material-symbols-outlined pf-section-hd__icon" style="color:#f59e0b">emoji_events</span>
                    Thành tích nổi bật
                </div>
                @if (thanhTich.Any())
                {
                    <ul class="pf-ach-list">
                        @foreach (var t in thanhTich)
                        {
                            <li class="pf-ach-item">
                                <span class="material-symbols-outlined pf-ach-item__icon">stars</span>
                                <span>@t</span>
                            </li>
                        }
                    </ul>
                }
                else
                {
                    <p class="pf-empty-txt">Chưa có thành tích nào.</p>
                }
            </div>

        </div>

        <div class="col-lg-8">

            <div class="ce-card p-4 mb-4">
                <div class="pf-section-hd mb-4">
                    <span class="material-symbols-outlined pf-section-hd__icon" style="color:var(--primary)">
                        @(isMe ? "manage_accounts" : "person")
                    </span>
                    @(isMe ? "Thông tin cá nhân" : "Thông tin liên hệ")
                </div>

                <div class="pf-info-grid mb-4">
                    <div class="pf-info-item">
                        <div class="pf-info-item__label">Mã sinh viên</div>
                        <div class="pf-info-item__val">@Model.ID</div>
                    </div>
                    <div class="pf-info-item">
                        <div class="pf-info-item__label">Họ và tên</div>
                        <div class="pf-info-item__val">@Model.Ten</div>
                    </div>
                    <div class="pf-info-item">
                        <div class="pf-info-item__label">Lớp</div>
                        <div class="pf-info-item__val">@(Model.Lop ?? "Chưa cập nhật")</div>
                    </div>
                    <div class="pf-info-item">
                        <div class="pf-info-item__label">Ngành</div>
                        <div class="pf-info-item__val">@(Model.MaNghanh ?? "Chưa cập nhật")</div>
                    </div>
                </div>

                @if (isMe)
                {
                    <div class="pf-divider mb-4"></div>
                    <p class="pf-section-sub mb-3">Thông tin có thể cập nhật</p>

                    using (Html.BeginForm("UpdateProfile", "Users", FormMethod.Post))
                    {
                        @Html.AntiForgeryToken()
                        <div class="row g-3">
                            <div class="col-sm-6">
                                <label class="ce-form-label">Ngày sinh</label>
                                <div class="ce-input-icon">
                                    <span class="material-symbols-outlined icon">cake</span>
                                    <input type="date" name="NgayThangNamSinh" class="ce-form-control"
                                           value="@(Model.NgayThangNamSinh.HasValue ? Model.NgayThangNamSinh.Value.ToString("yyyy-MM-dd") : "")" />
                                </div>
                            </div>
                            <div class="col-sm-6">
                                <label class="ce-form-label">Số điện thoại</label>
                                <div class="ce-input-icon">
                                    <span class="material-symbols-outlined icon">call</span>
                                    <input type="tel" name="SoDienThoai" class="ce-form-control"
                                           value="@Model.SoDienThoai" placeholder="09xxxxxxxx" />
                                </div>
                            </div>
                            <div class="col-12">
                                <label class="ce-form-label">Email</label>
                                <div class="ce-input-icon">
                                    <span class="material-symbols-outlined icon">mail</span>
                                    <input type="email" name="Email" class="ce-form-control"
                                           value="@Model.Email" placeholder="email@student.edu.vn" />
                                </div>
                            </div>
                            <div class="col-12 d-flex justify-content-end mt-2">
                                <button type="submit" class="ce-btn ce-btn-primary">
                                    <span class="material-symbols-outlined">save</span>
                                    Lưu thay đổi
                                </button>
                            </div>
                        </div>
                    }
                }
                else
                {
                    <div class="pf-divider mb-3"></div>
                    <div class="pf-info-grid">
                        <div class="pf-info-item">
                            <div class="pf-info-item__label">Số điện thoại</div>
                            <div class="pf-info-item__val">
                                @(string.IsNullOrEmpty(Model.SoDienThoai) ? "Chưa cập nhật" : Model.SoDienThoai)
                            </div>
                        </div>
                        <div class="pf-info-item">
                            <div class="pf-info-item__label">Email</div>
                            <div class="pf-info-item__val">
                                @(string.IsNullOrEmpty(Model.Email) ? "Chưa cập nhật" : Model.Email)
                            </div>
                        </div>
                    </div>
                }
            </div>

            <div class="ce-card p-4 mb-4">
                <div class="pf-section-hd mb-3">
                    <span class="material-symbols-outlined pf-section-hd__icon" style="color:#22c55e">verified</span>
                    Sự kiện đã hoàn thành HK @hocKy
                    <span class="pf-count-badge pf-count-badge--green ms-auto">@tongHT sự kiện</span>
                </div>

                @if (daThamDu.Any())
                {
                    <div class="pf-ev-list">
                        @foreach (var dk in daThamDu)
                        {
                            <div class="pf-ev-item">
                                <div class="pf-ev-item__icon pf-ev-item__icon--green">
                                    <span class="material-symbols-outlined">verified</span>
                                </div>
                                <div class="pf-ev-item__body">
                                    <div class="pf-ev-item__title">@dk.EVENT.TenEvent</div>
                                    <div class="pf-ev-item__meta">
                                        <span class="material-symbols-outlined">calendar_today</span>
                                        @dk.EVENT.NgayBatDau.ToString("dd/MM/yyyy")
                                    </div>
                                </div>
                                @if (dk.EVENT.DRL > 0)
                                {
                                    <span class="pf-ev-item__drl">+@dk.EVENT.DRL ĐRL</span>
                                }
                            </div>
                        }
                    </div>
                }
                else
                {
                    <div class="pf-empty">
                        <span class="material-symbols-outlined">event_busy</span>
                        <span>Chưa có sự kiện hoàn thành nào trong học kỳ này.</span>
                    </div>
                }
            </div>

            <div class="ce-card p-4">
                <div class="pf-section-hd mb-3">
                    <span class="material-symbols-outlined pf-section-hd__icon" style="color:var(--primary)">event_note</span>
                    Sự kiện đã tổ chức năm @currentYear
                    <span class="pf-count-badge pf-count-badge--blue ms-auto">@suKienNam.Count sự kiện</span>
                </div>

                @if (suKienNam.Any())
                {
                    <div class="pf-ev-list">
                        @foreach (var ev in suKienNam)
                        {
                            <a href="@Url.Action("EventDetail","Events", new { id = ev.MaEvent })"
                               class="pf-ev-item pf-ev-item--link">
                                <div class="pf-ev-item__icon pf-ev-item__icon--blue">
                                    <span class="material-symbols-outlined">event_note</span>
                                </div>
                                <div class="pf-ev-item__body">
                                    <div class="pf-ev-item__title">@ev.TenEvent</div>
                                    <div class="pf-ev-item__meta">
                                        <span class="material-symbols-outlined">calendar_today</span>
                                        @ev.NgayBatDau.ToString("dd/MM/yyyy")
                                        @if (ev.DiaDiem != null)
                                        {
                                            <span class="pf-ev-item__meta-sep">·</span>
                                            <span class="material-symbols-outlined">location_on</span>
                                            @ev.DiaDiem.TenDiaDiem
                                        }
                                    </div>
                                </div>
                                <span class="pf-ev-item__status">Đã đăng</span>
                            </a>
                        }
                    </div>
                }
                else
                {
                    <div class="pf-empty">
                        <span class="material-symbols-outlined">history</span>
                        <span>Chưa có sự kiện nào được tổ chức trong năm nay.</span>
                    </div>
                }
            </div>

        </div>
    </div>
</div>
