@{
    ViewBag.Title = "Xác thực tài khoản";
    Layout = null;
}
<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <title>@ViewBag.Title</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Lexend:wght@400;600&display=swap" rel="stylesheet" />
    <link href="~/Content/campus-variables.css" rel="stylesheet" />
    <link href="~/Content/campus-base.css" rel="stylesheet" />
    <link href="~/Content/campus-components.css" rel="stylesheet" />
    <style>
        body {
            font-family: 'Lexend', sans-serif;
            background: #f4f7fe;
        }

        .otp-container {
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .otp-card {
            background: #fff;
            padding: 40px;
            border-radius: 16px;
            box-shadow: 0 10px 30px rgba(0,0,0,0.05);
            width: 100%;
            max-width: 450px;
            text-align: center;
        }

        .otp-input {
            font-size: 2rem;
            letter-spacing: 8px;
            text-align: center;
            font-weight: bold;
            border: 2px solid #eee;
            border-radius: 12px;
            margin: 20px 0;
        }

            .otp-input:focus {
                border-color: var(--primary);
                box-shadow: none;
            }

        #resendBtn {
            background: none;
            border: none;
            color: #2D3FE2;
            font-weight: 600;
            cursor: pointer;
            padding: 0;
        }

            #resendBtn:disabled {
                color: #aaa;
                cursor: not-allowed;
            }
    </style>
</head>
<body>
    <div class="otp-container">
        <div class="otp-card">
            <h3 class="fw-bold mb-2">Xác nhận mã OTP</h3>
            <p class="text-muted small">Chúng tôi đã gửi mã xác thực 8 số đến email của bạn.</p>

            <div id="alertBox"></div>

            @if (ViewBag.Error != null)
            {
                <div class="alert alert-danger py-2 small">@ViewBag.Error</div>
            }

            @using (Html.BeginForm("VerifyOTP", "Account", FormMethod.Post))
            {
                <input type="text" name="otpInput" class="form-control otp-input"
                       placeholder="********" maxlength="8" required autocomplete="off" />
                <button type="submit" class="ce-btn ce-btn-primary ce-btn-block ce-btn-lg">
                    Xác nhận đăng ký
                </button>
            }

            <div class="mt-3 small text-muted">
                Không nhận được mã?
                <button id="resendBtn" onclick="resendOTP()" disabled>Gửi lại (<span id="countdown">30</span>s)</button>
            </div>
            <div class="mt-1 small text-muted">Còn <span id="remainCount">3</span> lần gửi lại</div>

            <div class="mt-4">
                <a href="@Url.Action("Login", "Account")" class="text-decoration-none small text-muted">
                    Quay lại trang đăng nhập
                </a>
            </div>
        </div>
    </div>

    <script>
        let seconds = 30;
        let remainCount = 3;
        let timer;

        function startCountdown() {
            seconds = 30;
            document.getElementById('resendBtn').disabled = true;
            timer = setInterval(() => {
                seconds--;
                document.getElementById('countdown').textContent = seconds;
                if (seconds <= 0) {
                    clearInterval(timer);
                    if (remainCount > 0) {
                        document.getElementById('resendBtn').disabled = false;
                        document.getElementById('resendBtn').textContent = 'Gửi lại mã';
                    }
                }
            }, 1000);
        }

        function resendOTP() {
            document.getElementById('resendBtn').disabled = true;

            fetch('@Url.Action("ResendOTP", "Account")', {
                method: 'POST',
                headers: { 'RequestVerificationToken': document.querySelector('input[name="__RequestVerificationToken"]').value }
            })
            .then(r => r.json())
            .then(data => {
                const alertBox = document.getElementById('alertBox');
                if (data.redirect) {
                    alertBox.innerHTML = `<div class="alert alert-warning py-2 small">${data.message}</div>`;
                    setTimeout(() => window.location.href = data.redirect, 2000);
                    return;
                }
                if (data.success) {
                    remainCount = data.remaining;
                    document.getElementById('remainCount').textContent = remainCount;
                    document.getElementById('resendBtn').innerHTML = `Gửi lại (<span id="countdown">30</span>s)`;
                    alertBox.innerHTML = `<div class="alert alert-success py-2 small">Đã gửi mã mới! Kiểm tra hộp thư.</div>`;
                    startCountdown();
                } else {
                    alertBox.innerHTML = `<div class="alert alert-danger py-2 small">${data.message}</div>`;
                }
            });
        }

        startCountdown(); // bắt đầu đếm ngược khi load trang
    </script>
</body>
</html>