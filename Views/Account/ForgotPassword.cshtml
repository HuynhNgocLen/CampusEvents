@{
    ViewBag.Title = "Khôi phục mật khẩu";
    Layout = null;
}

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewBag.Title – CampusEvents</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Lexend:wght@300;400;500;600;700;800&display=swap" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@20..48,100..700,0..1,-50..200" rel="stylesheet" />
    <link href="~/Content/campus-variables.css" rel="stylesheet" />
    <link href="~/Content/campus-base.css" rel="stylesheet" />
    <link href="~/Content/campus-components.css" rel="stylesheet" />
    <link href="~/Content/campus-pages.css" rel="stylesheet" />
    <link href="~/Content/campus-vibrant.css" rel="stylesheet" />
</head>
<body>
    <div class="ce-auth-page" style="display:flex; justify-content:center; align-items:center; min-height:100vh; background: var(--surface-bg);">
        <div class="ce-auth-card" style="width: 100%; max-width: 450px; padding: 2rem;">

            <div style="text-align:center; margin-bottom: 1.5rem;">
                <div style="width:56px; height:56px; background: #EEF0FD; border-radius: 16px;
                            display:inline-flex; align-items:center; justify-content:center; margin-bottom:1rem;">
                    <span class="material-symbols-outlined" style="font-size:28px; color:var(--primary);">lock_reset</span>
                </div>
                <div class="ce-auth-title" style="font-size: 1.5rem; margin-bottom: 0.35rem;">Khôi phục mật khẩu</div>
                <div class="ce-auth-sub" style="font-size: 0.875rem;">
                    Nhập MSSV hoặc Email — chúng tôi sẽ gửi link đặt lại mật khẩu đến Gmail của bạn.
                </div>
            </div>

            @if (TempData["Error"] != null)
            {
                <div class="alert alert-danger" style="font-size: 0.85rem; padding: 0.75rem; border-radius: 8px; margin-bottom: 1rem;">
                    <span class="material-symbols-outlined" style="font-size: 16px; vertical-align: text-bottom;">error</span>
                    @Html.Raw(TempData["Error"].ToString())
                </div>
            }

            @if (TempData["Success"] != null)
            {
                <div class="alert alert-success" style="font-size: 0.85rem; padding: 1rem; border-radius: 8px; margin-bottom: 1rem; text-align:center;">
                    <span class="material-symbols-outlined" style="font-size: 20px; vertical-align: middle; display:block; margin-bottom:6px;">mark_email_read</span>
                    @Html.Raw(TempData["Success"].ToString())
                    <div style="margin-top: 10px; font-size: 0.78rem; color: #555;">
                        Không thấy mail? Kiểm tra thư mục <b>Spam / Thư rác</b>.
                    </div>
                </div>
            }

            @using (Html.BeginForm("ForgotPassword", "Account", FormMethod.Post, new { autocomplete = "off" }))
            {
                @Html.AntiForgeryToken()

                <div class="mb-4">
                    <label class="ce-form-label">Mã sinh viên / Email</label>
                    <div class="ce-input-icon">
                        <span class="material-symbols-outlined icon">badge</span>
                        <input class="ce-form-control" name="identifier" type="text" required
                               placeholder="SV2021001234 hoặc email@student.tdmu.edu.vn"
                               autocomplete="off" />
                    </div>
                </div>

                <button class="ce-btn ce-btn-primary ce-btn-block ce-btn-lg mb-3" type="submit">
                    <span class="material-symbols-outlined">send</span> Gửi link đặt lại mật khẩu
                </button>

                <div style="text-align:center;">
                    <a href="@Url.Action("Login", "Account")" style="font-size:.85rem;color:var(--text-muted); text-decoration:none;">
                        <span class="material-symbols-outlined" style="font-size:14px; vertical-align:middle;">arrow_back</span> Quay lại đăng nhập
                    </a>
                </div>
            }
        </div>
    </div>
</body>
</html>
