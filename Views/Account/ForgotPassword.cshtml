@{
    ViewBag.Title = "Khôi phục mật khẩu";
    Layout = null;
}

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewBag.Title – CampusEvents</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Lexend:wght@300;400;500;600;700;800&display=swap" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@20..48,100..700,0..1,-50..200" rel="stylesheet" />
    <link href="~/Content/campus-variables.css" rel="stylesheet" />
    <link href="~/Content/campus-base.css" rel="stylesheet" />
    <link href="~/Content/campus-components.css" rel="stylesheet" />
    <link href="~/Content/campus-pages.css" rel="stylesheet" />
</head>
<body>
    <div class="ce-auth-page" style="display:flex; justify-content:center; align-items:center; min-height:100vh; background: var(--surface-bg);">
        <div class="ce-auth-card" style="width: 100%; max-width: 450px; padding: 2rem;">

            <div class="ce-auth-title" style="text-align:center; font-size: 1.5rem; margin-bottom: 0.5rem;">Khôi phục mật khẩu</div>
            <div class="ce-auth-sub" style="text-align:center; margin-bottom: 1.5rem;">Nhập MSSV hoặc Email để tạo mật khẩu mới</div>

            @* Thêm autocomplete="off" vào thẻ Form *@
            @using (Html.BeginForm("ForgotPassword", "Account", FormMethod.Post, new { id = "forgotPasswordForm", autocomplete = "off" }))
            {
                @Html.AntiForgeryToken()

                if (TempData["Error"] != null)
                {
                    <div class="alert alert-danger" style="font-size: 0.85rem; padding: 0.75rem; border-radius: 8px; margin-bottom: 1rem;">
                        <span class="material-symbols-outlined" style="font-size: 16px; vertical-align: text-bottom;">error</span>
                        @TempData["Error"]
                    </div>
                }

                <div class="mb-3">
                    <label class="ce-form-label">Mã sinh viên / Email</label>
                    <div class="ce-input-icon">
                        <span class="material-symbols-outlined icon">badge</span>
                        @* Thêm autocomplete="off" cho ô tài khoản *@
                        <input class="ce-form-control" name="identifier" type="text" required
                               placeholder="SV2021001234 hoặc email@student.abc.edu.vn"
                               autocomplete="off" />
                    </div>
                </div>

                <div class="mb-3">
                    <label class="ce-form-label">Mật khẩu mới</label>
                    <div class="ce-input-icon">
                        <span class="material-symbols-outlined icon">lock</span>
                        @* Thêm autocomplete="new-password" cho ô mật khẩu mới *@
                        <input class="ce-form-control" name="newPassword" type="password" required
                               id="pw-new" placeholder="Nhập mật khẩu mới" style="padding-right:2.8rem"
                               autocomplete="new-password" />
                        <button type="button" onclick="cePwToggle('pw-new',this)"
                                style="position:absolute;right:.7rem;top:50%;transform:translateY(-50%);background:none;border:none;cursor:pointer;color:var(--text-muted)">
                            <span class="material-symbols-outlined" style="font-size:17px">visibility</span>
                        </button>
                    </div>
                </div>

                <div class="mb-4">
                    <label class="ce-form-label">Nhập lại mật khẩu</label>
                    <div class="ce-input-icon">
                        <span class="material-symbols-outlined icon">lock_reset</span>
                        @* Thêm autocomplete="new-password" cho ô nhập lại mật khẩu *@
                        <input class="ce-form-control" name="confirmPassword" type="password" required
                               id="pw-confirm" placeholder="Xác nhận mật khẩu" style="padding-right:2.8rem"
                               autocomplete="new-password" />
                        <button type="button" onclick="cePwToggle('pw-confirm',this)"
                                style="position:absolute;right:.7rem;top:50%;transform:translateY(-50%);background:none;border:none;cursor:pointer;color:var(--text-muted)">
                            <span class="material-symbols-outlined" style="font-size:17px">visibility</span>
                        </button>
                    </div>
                    <small id="pw-error" class="text-danger" style="display:none; font-size:0.75rem; margin-top:5px;">Mật khẩu xác nhận không khớp!</small>
                </div>

                <button class="ce-btn ce-btn-primary ce-btn-block ce-btn-lg mb-3" type="submit">
                    <span class="material-symbols-outlined">save</span> Xác nhận đổi mật khẩu
                </button>

                <div style="text-align:center;">
                    <a href="@Url.Action("Login", "Account")" style="font-size:.85rem;color:var(--text-muted); text-decoration:none;">
                        <span class="material-symbols-outlined" style="font-size:14px; vertical-align:middle;">arrow_back</span> Quay lại đăng nhập
                    </a>
                </div>
            }
        </div>
    </div>

    <script>
        function cePwToggle(id, btn) {
            var inp = document.getElementById(id);
            var isText = inp.type === 'text';
            inp.type = isText ? 'password' : 'text';
            btn.querySelector('.material-symbols-outlined').textContent = isText ? 'visibility' : 'visibility_off';
        }

        // JS kiểm tra mật khẩu khớp nhau trước khi submit
        document.getElementById('forgotPasswordForm').addEventListener('submit', function (e) {
            var p1 = document.getElementById('pw-new').value;
            var p2 = document.getElementById('pw-confirm').value;
            if (p1 !== p2) {
                e.preventDefault(); // Ngăn form submit
                document.getElementById('pw-error').style.display = 'block';
            } else {
                document.getElementById('pw-error').style.display = 'none';
            }
        });
    </script>
</body>
</html>