@{
    ViewBag.Title = "Đặt lại mật khẩu";
    Layout = null;
}

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewBag.Title – CampusEvents</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Lexend:wght@300;400;500;600;700;800&display=swap" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@20..48,100..700,0..1,-50..200" rel="stylesheet" />
    <link href="~/Content/app/campus-variables.css" rel="stylesheet" />
    <link href="~/Content/app/campus-base.css" rel="stylesheet" />
    <link href="~/Content/app/campus-components.css" rel="stylesheet" />
    <link href="~/Content/app/campus-pages.css" rel="stylesheet" />
    <link href="~/Content/app/campus-vibrant.css" rel="stylesheet" />
</head>
<body>
    <div class="ce-auth-page" style="display:flex; justify-content:center; align-items:center; min-height:100vh; background: var(--surface-bg);">
        <div class="ce-auth-card" style="width: 100%; max-width: 450px; padding: 2rem;">

            <div style="text-align:center; margin-bottom: 1.5rem;">
                <div style="width:56px; height:56px; background: #EEF0FD; border-radius: 16px;
                            display:inline-flex; align-items:center; justify-content:center; margin-bottom:1rem;">
                    <span class="material-symbols-outlined" style="font-size:28px; color:var(--primary);">lock</span>
                </div>
                <div class="ce-auth-title" style="font-size: 1.5rem; margin-bottom: 0.35rem;">Đặt lại mật khẩu</div>
                <div class="ce-auth-sub" style="font-size: 0.875rem;">Nhập mật khẩu mới cho tài khoản của bạn.</div>
            </div>

            @if (ViewBag.Error != null)
            {
                <div class="alert alert-danger" style="font-size: 0.85rem; padding: 0.75rem; border-radius: 8px; margin-bottom: 1rem;">
                    <span class="material-symbols-outlined" style="font-size: 16px; vertical-align: text-bottom;">error</span>
                    @ViewBag.Error
                </div>
            }

            @using (Html.BeginForm("ResetPassword", "Account", FormMethod.Post, new { id = "resetForm", autocomplete = "off" }))
            {
                @Html.AntiForgeryToken()
                <input type="hidden" name="token" value="@ViewBag.Token" />

                <div class="mb-3">
                    <label class="ce-form-label">Mật khẩu mới</label>
                    <div class="ce-input-icon">
                        <span class="material-symbols-outlined icon">lock</span>
                        <input class="ce-form-control" name="newPassword" type="password" required
                               id="pw-new" placeholder="Tối thiểu 8 ký tự" style="padding-right:2.8rem"
                               autocomplete="new-password" />
                        <button type="button" onclick="cePwToggle('pw-new', this)"
                                style="position:absolute;right:.7rem;top:50%;transform:translateY(-50%);background:none;border:none;cursor:pointer;color:var(--text-muted)">
                            <span class="material-symbols-outlined" style="font-size:17px">visibility</span>
                        </button>
                    </div>
                </div>

                <div class="mb-4">
                    <label class="ce-form-label">Xác nhận mật khẩu</label>
                    <div class="ce-input-icon">
                        <span class="material-symbols-outlined icon">lock_reset</span>
                        <input class="ce-form-control" name="confirmPassword" type="password" required
                               id="pw-confirm" placeholder="Nhập lại mật khẩu" style="padding-right:2.8rem"
                               autocomplete="new-password" />
                        <button type="button" onclick="cePwToggle('pw-confirm', this)"
                                style="position:absolute;right:.7rem;top:50%;transform:translateY(-50%);background:none;border:none;cursor:pointer;color:var(--text-muted)">
                            <span class="material-symbols-outlined" style="font-size:17px">visibility</span>
                        </button>
                    </div>
                    <small id="pw-error" class="text-danger" style="display:none; font-size:0.75rem; margin-top:5px;">
                        Mật khẩu xác nhận không khớp!
                    </small>
                </div>

                <button class="ce-btn ce-btn-primary ce-btn-block ce-btn-lg mb-3" type="submit">
                    <span class="material-symbols-outlined">save</span> Xác nhận đổi mật khẩu
                </button>

                <div style="text-align:center;">
                    <a href="@Url.Action("Login", "Account")" style="font-size:.85rem;color:var(--text-muted); text-decoration:none;">
                        <span class="material-symbols-outlined" style="font-size:14px; vertical-align:middle;">arrow_back</span> Quay lại đăng nhập
                    </a>
                </div>
            }
        </div>
    </div>

    <script>
        function cePwToggle(id, btn) {
            var inp = document.getElementById(id);
            var isText = inp.type === 'text';
            inp.type = isText ? 'password' : 'text';
            btn.querySelector('.material-symbols-outlined').textContent = isText ? 'visibility' : 'visibility_off';
        }

        document.getElementById('resetForm').addEventListener('submit', function (e) {
            var p1 = document.getElementById('pw-new').value;
            var p2 = document.getElementById('pw-confirm').value;
            var errEl = document.getElementById('pw-error');
            if (p1 !== p2) {
                e.preventDefault();
                errEl.style.display = 'block';
            } else {
                errEl.style.display = 'none';
            }
        });
    </script>
</body>
</html>
