@* Filter.cshtml – Redesigned *@
@using System.Linq

@{
    var qVien = (Request.QueryString.GetValues("vien") ?? new string[0]).ToList();
    var qDM = (Request.QueryString.GetValues("danhmuc") ?? new string[0]).ToList();
    var qTime = Request.QueryString["time"] ?? "all";
    var qStatus = (Request.QueryString.GetValues("status") ?? new string[0]).ToList();

    /* Đếm số filter đang active (bỏ qua "all") */
    int activeCount = 0;
    if (!qVien.Contains("all") && qVien.Count > 0) { activeCount += qVien.Count; }
    if (!qDM.Contains("all") && qDM.Count > 0) { activeCount += qDM.Count; }
    if (qTime != "all") { activeCount++; }
    if (!qStatus.Contains("all") && qStatus.Count > 0) { activeCount += qStatus.Count; }
}

<div class="cef-backdrop" id="cef-backdrop" onclick="closeFilter()"></div>

<div class="col-lg-3">
    <form method="get" action="@Url.Action("Events","Events")" id="filter-form">
        <div class="cef-panel" id="ce-filter-sidebar">

            <div class="cef-panel__head">
                <div class="cef-panel__title">
                    <span class="material-symbols-outlined">tune</span>
                    Bộ lọc
                    <span class="cef-badge-count" id="filter-count"
                          style="@(activeCount > 0 ? "" : "display:none")">@activeCount</span>
                    </div>

                    <button type="button" class="cef-close-btn d-lg-none" onclick="closeFilter()" aria-label="Đóng">
                        <span class="material-symbols-outlined">close</span>
                    </button>

                    <a href="@Url.Action("Events","Events")"
                       class="cef-reset-link d-none d-lg-flex"
                       style="@(activeCount > 0 ? "" : "visibility:hidden")">
                        Xóa tất cả
                    </a>
                </div>

                <div class="cef-panel__body">

                    <div class="cef-group" data-group="vien">
                        <button type="button" class="cef-group__toggle" aria-expanded="false">
                            <div class="cef-group__toggle-left">
                                <span class="material-symbols-outlined">account_balance</span>
                                Viện / Khoa
                            </div>
                            <span class="material-symbols-outlined cef-chevron">expand_less</span>
                        </button>
                        <div class="cef-group__body">
                            <label class="cef-check">
                                <input type="checkbox" name="vien" value="all" class="check-all"
                                       @(qVien.Count == 0 || qVien.Contains("all") ? "checked" : "") />
                                <span class="cef-check__box"></span>
                                <span class="cef-check__label">Tất cả</span>
                            </label>

                            @if (ViewBag.ListVien != null)
                            {
                                foreach (var v in ViewBag.ListVien)
                                {
                                    <label class="cef-check">
                                        <input type="checkbox" name="vien" value="@v.MaVien" class="check-item"
                                               @(qVien.Contains(v.MaVien.ToString()) ? "checked" : "") />
                                        <span class="cef-check__box"></span>
                                        <span class="cef-check__label">@v.TenVien</span>
                                    </label>
                                }
                            }
                        </div>
                    </div>

                    <div class="cef-divider"></div>

                    <div class="cef-group" data-group="danhmuc">
                        <button type="button" class="cef-group__toggle" aria-expanded="false">
                            <div class="cef-group__toggle-left">
                                <span class="material-symbols-outlined">category</span>
                                Danh mục
                            </div>
                            <span class="material-symbols-outlined cef-chevron">expand_less</span>
                        </button>
                        <div class="cef-group__body">
                            <label class="cef-check">
                                <input type="checkbox" name="danhmuc" value="all" class="check-all"
                                       @(qDM.Count == 0 || qDM.Contains("all") ? "checked" : "") />
                                <span class="cef-check__box"></span>
                                <span class="cef-check__label">Tất cả</span>
                            </label>

                            @if (ViewBag.DanhMucs != null)
                            {
                                foreach (var d in ViewBag.DanhMucs)
                                {
                                    <label class="cef-check">
                                        <input type="checkbox" name="danhmuc" value="@d.MaDanhMuc" class="check-item"
                                               @(qDM.Contains(d.MaDanhMuc.ToString()) ? "checked" : "") />
                                        <span class="cef-check__box"></span>
                                        <span class="cef-check__label">@d.TenDanhMuc</span>
                                    </label>
                                }
                            }
                        </div>
                    </div>

                    <div class="cef-divider"></div>

                    <div class="cef-group" data-group="time">
                        <button type="button" class="cef-group__toggle" aria-expanded="false">
                            <div class="cef-group__toggle-left">
                                <span class="material-symbols-outlined">calendar_month</span>
                                Thời gian
                            </div>
                            <span class="material-symbols-outlined cef-chevron">expand_less</span>
                        </button>
                        <div class="cef-group__body">
                            <div class="cef-time-grid">
                                @{
                                    var timeList = new[] {
                                    new { Val = "all",   Label = "Tất cả",    Icon = "all_inclusive" },
                                    new { Val = "today", Label = "Hôm nay",   Icon = "today" },
                                    new { Val = "week",  Label = "Tuần này",  Icon = "date_range" },
                                    new { Val = "month", Label = "Tháng này", Icon = "calendar_view_month" }
                                };
                                }
                                @foreach (var t in timeList)
                                {
                                    <label class="cef-time-pill @(qTime == t.Val ? "active" : "")" for="time_@t.Val">
                                        <input type="radio"
                                               id="time_@t.Val"
                                               name="time"
                                               value="@t.Val"
                                               @(qTime == t.Val ? "checked=\"checked\"" : "") />
                                        <span class="material-symbols-outlined">@t.Icon</span>
                                        @t.Label
                                    </label>
                                }
                            </div>
                        </div>
                    </div>

                    <div class="cef-divider"></div>

                    <div class="cef-group" data-group="status" data-exclusive="true">
                        <button type="button" class="cef-group__toggle" aria-expanded="false">
                            <div class="cef-group__toggle-left">
                                <span class="material-symbols-outlined">info</span>
                                Trạng thái
                            </div>
                            <span class="material-symbols-outlined cef-chevron">expand_less</span>
                        </button>
                        <div class="cef-group__body">
                            <label class="cef-check">
                                <input type="checkbox" name="status" value="all" class="check-all"
                                       @(qStatus.Count == 0 || qStatus.Contains("all") ? "checked" : "") />
                                <span class="cef-check__box"></span>
                                <span class="cef-check__label">Tất cả</span>
                            </label>
                            <label class="cef-check">
                                <input type="checkbox" name="status" value="available" class="check-item"
                                       @(qStatus.Contains("available") ? "checked" : "") />
                                <span class="cef-check__box"></span>
                                <span class="cef-check__label">
                                    <span class="cef-dot cef-dot--green"></span> Còn chỗ
                                </span>
                            </label>
                            <label class="cef-check">
                                <input type="checkbox" name="status" value="almost" class="check-item"
                                       @(qStatus.Contains("almost") ? "checked" : "") />
                                <span class="cef-check__box"></span>
                                <span class="cef-check__label">
                                    <span class="cef-dot cef-dot--orange"></span> Sắp đầy
                                </span>
                            </label>
                            <label class="cef-check">
                                <input type="checkbox" name="status" value="free" class="check-item"
                                       @(qStatus.Contains("free") ? "checked" : "") />
                                <span class="cef-check__box"></span>
                                <span class="cef-check__label">
                                    <span class="cef-dot cef-dot--blue"></span> Miễn phí
                                </span>
                            </label>
                        </div>
                    </div>

                </div><div class="cef-panel__foot">
                    <button type="submit" class="cef-btn-apply">
                        <span class="material-symbols-outlined">check_circle</span>
                        Áp dụng bộ lọc
                    </button>
                    <a href="@Url.Action("Events","Events")" class="cef-btn-reset">
                        <span class="material-symbols-outlined">refresh</span>
                        Xóa lọc
                    </a>
                </div>

            </div>
        </form>
    </div>