@model IEnumerable<shcool_event_management.Models.DangKySuKien>

@{
    Layout = "~/Views/Shared/_LayoutUsers.cshtml";
    DateTime startOfWeek = ViewBag.StartOfWeek;
    DateTime endOfWeek = ViewBag.EndOfWeek;
}

<div class="container py-4">
    <div class="d-flex flex-wrap justify-content-between align-items-center mb-4 gap-3">
        <h4 class="fw-bold mb-0">
            <span class="material-symbols-outlined align-middle me-2 text-primary">calendar_month</span>
            Lịch sự kiện của tôi
        </h4>

        <div class="d-flex align-items-center gap-2">
            @if (ViewBag.WeekOffset != 0)
            {
                <a href="@Url.Action("Schedule", new { offset = 0 })" class="ce-btn" style="border: 1px solid var(--border); color: var(--text); padding: 0.35rem 0.8rem;">
                    Tuần này
                </a>
            }

            <a href="@Url.Action("Schedule", new { offset = ViewBag.WeekOffset - 1 })" class="ce-btn" style="border: 1px solid var(--border); color: var(--text); padding: 0.35rem;">
                <span class="material-symbols-outlined">chevron_left</span>
            </a>

            <div class="ce-badge ce-badge-primary fs-6" style="min-width: 220px; justify-content: center;">
                @(ViewBag.WeekOffset == 0 ? "Tuần này: " : "") @startOfWeek.ToString("dd/MM") - @endOfWeek.ToString("dd/MM/yyyy")
            </div>

            <a href="@Url.Action("Schedule", new { offset = ViewBag.WeekOffset + 1 })" class="ce-btn" style="border: 1px solid var(--border); color: var(--text); padding: 0.35rem;">
                <span class="material-symbols-outlined">chevron_right</span>
            </a>
        </div>
    </div>

    <div class="row">
        <div class="col-12">
            @if (!Model.Any())
            {
                <div class="ce-card p-5 text-center text-muted">
                    <span class="material-symbols-outlined" style="font-size: 48px; color: #cbd5e1;">event_busy</span>
                    <h5 class="mt-3" style="color: var(--text-muted);">Tuần này bạn không có sự kiện nào</h5>
                    <p class="mb-0" style="color: var(--text-muted);">Hãy quay lại trang Khám phá để tìm kiếm thêm các sự kiện thú vị nhé!</p>
                    <a href="@Url.Action("Events", "Events")" class="ce-btn ce-btn-primary mt-3">Khám phá ngay</a>
                </div>
            }
            else
            {
                <div class="ce-card p-4">
                    <div class="timeline-container">
                        @for (int i = 0; i < 7; i++)
                        {
                            DateTime currentDate = startOfWeek.AddDays(i);
                            // Lấy ra các sự kiện của ngày đang lặp
                            var eventsToday = Model.Where(d => d.EVENT.NgayBatDau.Date == currentDate.Date).ToList();

                            <div class="mb-4">
                                <h6 class="fw-bold border-bottom pb-2" style="color: @(currentDate.Date == DateTime.Today.Date ? "var(--primary)" : "var(--text)");">
                                    @(i == 6 ? "Chủ Nhật" : $"Thứ {i + 2}"), @currentDate.ToString("dd/MM/yyyy")
                                    @if (currentDate.Date == DateTime.Today.Date)
                                    {
                                        <span class="badge" style="background-color: var(--primary); font-size: 12px; margin-left: 8px;">Hôm nay</span>
                                    }
                                </h6>

                                @if (eventsToday.Any())
                                {
                                    <div class="row mt-3">
                                        @foreach (var dk in eventsToday)
                                        {
                                            <div class="col-md-6 mb-3">
                                                <div class="ce-card h-100 p-3" style="border: 1px solid var(--border);">
                                                    <div class="d-flex justify-content-between mb-2">
                                                        <span class="badge" style="background-color: @(dk.EVENT.DanhMuc?.MauSac ?? "#6c757d")">
                                                            @dk.EVENT.DanhMuc.TenDanhMuc
                                                        </span>
                                                        <small style="color: var(--text-muted); font-weight: 600;">
                                                            <span class="material-symbols-outlined align-middle" style="font-size: 16px;">schedule</span>
                                                            @dk.EVENT.NgayBatDau.ToString("HH:mm")
                                                            @(dk.EVENT.GioKetThuc.HasValue ? $"- {dk.EVENT.GioKetThuc.Value.ToString(@"hh\:mm")}" : "")
                                                        </small>
                                                    </div>
                                                    <h6 class="fw-bold text-truncate mb-2" title="@dk.EVENT.TenEvent">
                                                        <a href="@Url.Action("EventDetail", "Events", new { id = dk.MaEvent })" style="color: var(--text); text-decoration: none;">
                                                            @dk.EVENT.TenEvent
                                                        </a>
                                                    </h6>
                                                    <p class="small mb-0" style="color: var(--text);">
                                                        <span class="material-symbols-outlined align-middle" style="font-size: 16px;">location_on</span>
                                                        @(dk.EVENT.DiaDiem != null ? dk.EVENT.DiaDiem.TenDiaDiem : "Chưa cập nhật")
                                                    </p>
                                                </div>
                                            </div>
                                        }
                                    </div>
                                }
                                else
                                {
                                    <p class="text-muted small fst-italic mt-2 mb-0">Không có lịch trình.</p>
                                }
                            </div>
                        }
                    </div>
                </div>
            }
        </div>
    </div>
</div>