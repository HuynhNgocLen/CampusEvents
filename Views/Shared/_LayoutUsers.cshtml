<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewBag.Title – CampusEvents</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Lexend:wght@300;400;500;600;700;800&display=swap" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@20..48,100..700,0..1,-50..200" rel="stylesheet" />

    <!-- toastr CSS -->
    <link href="https://cdnjs.cloudflare.com/ajax/libs/toastr.js/latest/toastr.min.css" rel="stylesheet" />

    <link href="@Url.Content("~/Content/campus-variables.css")" rel="stylesheet" />
    <link href="@Url.Content("~/Content/campus-base.css")" rel="stylesheet" />
    <link href="@Url.Content("~/Content/campus-navbar.css")" rel="stylesheet" />
    <link href="@Url.Content("~/Content/campus-components.css")" rel="stylesheet" />
    <link href="@Url.Content("~/Content/campus-pages.css")" rel="stylesheet" />
    <link href="@Url.Content("~/Content/campus-filter.css")" rel="stylesheet" />
    <link href="@Url.Content("~/Content/campus-profile.css")" rel="stylesheet" />
    <link href="@Url.Content("~/Content/campus-index.css")" rel="stylesheet" />
    <link href="@Url.Content("~/Content/campus-vibrant.css")" rel="stylesheet" />
    @RenderSection("styles", required: false)
</head>
<body>
    @{
        var _jwt = Request.Cookies["jwt"];
        var _jwtOk = _jwt != null && school_event_management.Models.JwtService.ValidateToken(_jwt.Value) != null;
        var isGuestUser = _jwtOk && school_event_management.Models.JwtService.IsGuest(Request);
    }

    <nav class="ce-navbar">
        <a href="@Url.Action("Home", "Home")" class="ce-navbar__brand">
            <div class="ce-navbar__logo">
                <span class="material-symbols-outlined">school</span>
            </div>
            <span class="ce-navbar__name">CampusEvents</span>
        </a>

        @if (!isGuestUser)
        {
            <div class="ce-navbar__search d-none d-md-block">
                <form action="@Url.Action("Events", "Events")" method="GET" class="ce-navbar__search d-none d-md-block">
                    <span class="material-symbols-outlined si">search</span>
                    <input type="search" name="keyword" placeholder="Tìm kiếm sự kiện…" id="navbar-search" value="@Request.QueryString["keyword"]" />
                </form>
            </div>
        }

        <div class="ce-navbar__nav">
            <a href="@Url.Action("Home", "Home")" class="@(ViewBag.ActivePage == "home" ? "active" : "")">
                <span class="material-symbols-outlined">home</span> Trang chủ
            </a>
            @if (!isGuestUser)
            {
                <a href="@Url.Action("Events", "Events")" class="@(ViewBag.ActivePage == "events" ? "active" : "")">
                    <span class="material-symbols-outlined">event</span> Sự kiện
                </a>
                <a href="@Url.Action("Registrations", "Registration")" class="@(ViewBag.ActivePage == "registrations" ? "active" : "")">
                    <span class="material-symbols-outlined">assignment_turned_in</span> Đăng ký của tôi
                </a>
                <a href="@Url.Action("Schedule", "Schedule")" class="@(ViewBag.ActivePage == "schedule" ? "active" : "")">
                    <span class="material-symbols-outlined">calendar_month</span> Lịch của tôi
                </a>
            }
        </div>

        <div class="ce-navbar__actions">
            <button class="ce-navbar__icon-btn" data-action="toggle-theme" title="Đổi giao diện">
                <span class="material-symbols-outlined ce-theme-icon">light_mode</span>
            </button>
            @if (!isGuestUser)
            {
                <button class="ce-navbar__icon-btn" title="Thông báo"
                        onclick="ceOpenModal('modal-notif')">
                    <span class="material-symbols-outlined">notifications</span>
                    <span class="ce-notif-dot"></span>
                </button>
            }
            @if (_jwtOk)
            {
                @* Đã có JWT (sinh viên hoặc khách) *@
                <div class="dropdown">
                    <a href="#" class="ce-navbar__avatar" data-bs-toggle="dropdown" aria-expanded="false" title="Tài khoản">
                        @{
                            var name = ViewBag.UserName as string ?? "SV";
                            var initials = name.Length >= 2 ? name.Substring(0, 2).ToUpper() : name.ToUpper();
                        }
                        @initials
                    </a>
                    <ul class="dropdown-menu dropdown-menu-end shadow-sm border-0" style="border-radius: 12px; margin-top: 10px; background: var(--surface);">
                        @if (!isGuestUser)
                        {
                            <li><a class="dropdown-item py-2" href="@Url.Action("Profile", "Home")" style="color: var(--text)"><span class="material-symbols-outlined v-align-middle me-2" style="font-size:20px; color: var(--text);">person</span> Hồ sơ cá nhân</a></li>
                            <li><hr class="dropdown-divider"></li>
                            <li><a class="dropdown-item py-2" href="@Url.Action("Settings", "Home")" style="color: var(--text)"><span class="material-symbols-outlined v-align-middle me-2" style="font-size:20px; color: var(--text);">settings</span> Cài đặt</a></li>
                            <li><hr class="dropdown-divider"></li>
                            <li><a class="dropdown-item py-2" href="@Url.Action("Registrations", "Registration")" style="color: var(--text)"><span class="material-symbols-outlined v-align-middle me-2" style="font-size:20px; color: var(--text);">assignment_turned_in</span> Tổng quan đăng ký</a></li>
                            <li><hr class="dropdown-divider"></li>
                        }
                        else
                        {
                            <li><span class="dropdown-item py-2 text-muted" style="font-size:.8rem;cursor:default">Chế độ khách — chỉ trang chủ</span></li>
                            <li><hr class="dropdown-divider"></li>
                        }
                        <li><a class="dropdown-item py-2 text-danger" href="@Url.Action("Logout", "Account")"><span class="material-symbols-outlined v-align-middle me-2" style="font-size:20px;">logout</span> Đăng xuất</a></li>
                    </ul>
                </div>
            }
            else
            {
                @* TRƯỜNG HỢP: CHƯA ĐĂNG NHẬP *@
                <a href="@Url.Action("Login", "Account")" class="ce-navbar__login-btn d-flex align-items-center gap-2" title="Đăng nhập hệ thống">
                    <div class="ce-navbar__avatar-guest">
                        <span class="material-symbols-outlined" style="font-size: 20px; color: var(--text-muted);">person</span>
                    </div>
                    <span class="d-none d-sm-inline" style="font-size: 0.85rem; font-weight: 600; color: var(--text);">Đăng nhập</span>
                </a>
            }
            <button class="ce-navbar__toggler" id="ce-nav-toggler" aria-label="Menu">
                <span class="material-symbols-outlined">menu</span>
            </button>
        </div>
    </nav>

    <div class="ce-mobile-menu" id="ce-mobile-menu">
        <div class="ce-mobile-menu__content">
            <div class="ce-mobile-menu__header">
                <span class="ce-navbar__name">Menu</span>
            </div>
            <div class="ce-mobile-menu__nav">
                <a href="@Url.Action("Home", "Home")" class="@(ViewBag.ActivePage == "home" ? "active" : "")">
                    <span class="material-symbols-outlined">home</span> Trang chủ
                </a>
                @if (!isGuestUser)
                {
                    <a href="@Url.Action("Settings", "Home")" class="@(ViewBag.ActivePage == "settings" ? "active" : "")">
                        <span class="material-symbols-outlined">settings</span> Cài đặt
                    </a>
                    <a href="@Url.Action("Events", "Events")" class="@(ViewBag.ActivePage == "events" ? "active" : "")">
                        <span class="material-symbols-outlined">event</span> Sự kiện
                    </a>
                    <a href="@Url.Action("Registrations", "Registration")" class="@(ViewBag.ActivePage == "registrations" ? "active" : "")">
                        <span class="material-symbols-outlined">assignment_turned_in</span> Đăng ký của tôi
                    </a>
                    <a href="@Url.Action("Schedule", "Schedule")" class="@(ViewBag.ActivePage == "schedule" ? "active" : "")">
                        <span class="material-symbols-outlined">calendar_month</span> Lịch của tôi
                    </a>
                }
            </div>
        </div>
    </div>

    @if (!isGuestUser)
    {
        <div class="ce-modal-overlay" id="modal-notif">
            <div class="ce-modal-box">
                <div class="ce-modal-header">
                    <h5 class="d-flex align-items-center gap-2">
                        <span class="material-symbols-outlined" style="font-size:20px;color:var(--primary)">notifications</span>
                        Thông báo
                    </h5>
                    <button class="ce-modal-close" type="button" onclick="ceCloseModal('modal-notif')">
                        <span class="material-symbols-outlined">close</span>
                    </button>
                </div>
                <div class="ce-modal-body pt-3">
                    <div class="d-flex justify-content-end gap-2 mb-3">
                        <button id="ce-notif-read-all" type="button" class="ce-btn ce-btn-ghost ce-btn-sm">
                            <span class="material-symbols-outlined">drafts</span>
                            Đọc tất cả
                        </button>
                        <button id="ce-notif-clear-all" type="button" class="ce-btn ce-btn-danger ce-btn-sm">
                            <span class="material-symbols-outlined">delete</span>
                            Xóa tất cả
                        </button>
                    </div>
                    <div id="ce-notif-list" class="d-flex flex-column gap-2"></div>
                </div>
                <div class="ce-modal-footer">
                    <button type="button" class="ce-btn ce-btn-primary" onclick="ceCloseModal('modal-notif')">Đóng</button>
                </div>
            </div>
        </div>
    }

    @* ── PAGE WRAPPER ── *@
    <div class="ce-page-wrapper">
        @if (isGuestUser)
        {
            <div class="ce-guest-banner">
                <span class="material-symbols-outlined" style="font-size:18px;flex-shrink:0">info</span>
                <span>Bạn đang xem với tư cách <strong>khách</strong> — chỉ trang chủ. Đăng xuất rồi đăng nhập sinh viên để dùng đầy đủ chức năng.</span>
            </div>
        }
        <main class="ce-main">
            @RenderSection("Hero", required: false)
            @RenderBody()
        </main>

        <footer class="ce-footer" style="background: var(--surface); padding: 60px 0 20px; border-top: 1px solid var(--border); margin-top: 2rem;">
            <div class="container">
                <div class="row g-4 mb-5">
                    <div class="col-12 col-lg-4">
                        <div class="d-flex align-items-center gap-2 mb-3">
                            <div style="width:40px;height:40px;background:var(--primary);border-radius:12px;display:flex;align-items:center;justify-content:center">
                                <span class="material-symbols-outlined" style="color:#fff;font-size:24px">school</span>
                            </div>
                            <span style="font-size:1.2rem;font-weight:900;color:var(--text)">Campus<span style="color:var(--primary)">Events</span></span>
                        </div>
                        <p style="font-size:0.9rem;color:var(--text-muted);max-width:280px;line-height:1.6">
                            Nền tảng kết nối sinh viên với hàng ngàn sự kiện thú vị tại khuôn viên trường đại học của bạn.
                        </p>
                        <div class="d-flex gap-3 mt-4">
                            <a href="#" class="dash-footer__social-modern" title="Facebook" style="color:var(--text-muted);transition:color .2s;"><span class="material-symbols-outlined">language</span></a>
                            <a href="#" class="dash-footer__social-modern" title="Zalo" style="color:var(--text-muted);transition:color .2s;"><span class="material-symbols-outlined">chat</span></a>
                            <a href="#" class="dash-footer__social-modern" title="Email" style="color:var(--text-muted);transition:color .2s;"><span class="material-symbols-outlined">mail</span></a>
                        </div>
                    </div>
                    <div class="col-6 col-md-2 offset-lg-2">
                        <div class="ce-footer__heading-modern" style="font-weight:800;color:var(--text);margin-bottom:16px;font-size:0.95rem;text-transform:uppercase;">Khám phá</div>
                        <ul class="list-unstyled d-flex flex-column gap-2" style="font-size:0.9rem;">
                            <li><a href="@Url.Action("Events","Events")" style="color:var(--text-muted);text-decoration:none;">Sự kiện</a></li>
                            <li><a href="@Url.Action("Events","Events",new{category="CLUB"})" style="color:var(--text-muted);text-decoration:none;">Câu lạc bộ</a></li>
                            <li><a href="@Url.Action("Notifications","Home")" style="color:var(--text-muted);text-decoration:none;">Lịch của tôi</a></li>
                        </ul>
                    </div>
                    <div class="col-6 col-md-2">
                        <div class="ce-footer__heading-modern" style="font-weight:800;color:var(--text);margin-bottom:16px;font-size:0.95rem;text-transform:uppercase;">Pháp lý</div>
                        <ul class="list-unstyled d-flex flex-column gap-2" style="font-size:0.9rem;">
                            <li><a href="#" style="color:var(--text-muted);text-decoration:none;">Quyền riêng tư</a></li>
                            <li><a href="#" style="color:var(--text-muted);text-decoration:none;">Điều khoản sử dụng</a></li>
                            <li><a href="#" style="color:var(--text-muted);text-decoration:none;">Trung tâm trợ giúp</a></li>
                        </ul>
                    </div>
                    <div class="col-6 col-md-2">
                        <div class="ce-footer__heading-modern" style="font-weight:800;color:var(--text);margin-bottom:16px;font-size:0.95rem;text-transform:uppercase;">Đăng nhập</div>
                        <ul class="list-unstyled d-flex flex-column gap-2" style="font-size:0.9rem;">
                            <li><a href="@Url.Action("Profile","Home")" style="color:var(--text-muted);text-decoration:none;">Hồ sơ của tôi</a></li>
                            <li><a href="@Url.Action("Login","Account")" style="color:var(--text-muted);text-decoration:none;">Đăng nhập / Đăng ký</a></li>
                        </ul>
                    </div>
                </div>
                <div class="d-flex flex-column flex-md-row justify-content-between align-items-center pt-4" style="border-top:1px solid var(--border);font-size:0.85rem;color:var(--text-muted);">
                    <span class="mb-2 mb-md-0">© 2026 Campus Events. Nền tảng sự kiện sinh viên.</span>
                    <span>Made with <span style="color:#ef4444">♥</span> for students</span>
                </div>
            </div>
            <style>
                .dash-footer__social-modern:hover { color: var(--primary) !important; }
                .ce-footer__heading-modern { letter-spacing: 0.5px; }
                .ce-footer ul li a:hover { color: var(--primary) !important; text-decoration: underline !important; }
            </style>
        </footer>
    </div>

    <!-- Scripts -->
    <script src="https://cdn.jsdelivr.net/npm/jquery@3.7.1/dist/jquery.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>

    <!-- toastr JS -->
    <script src="https://cdnjs.cloudflare.com/ajax/libs/toastr.js/latest/toastr.min.js"></script>

    <script src="@Url.Content("~/Scripts/campus-app.js")"></script>

    @if (TempData["Info"] != null)
    {
        var flashInfo = TempData["Info"].ToString();
        <script>
            document.addEventListener('DOMContentLoaded', function () {
                if (typeof CeToast !== 'undefined')
                    CeToast.show(@Html.Raw(System.Web.HttpUtility.JavaScriptStringEncode(flashInfo, true)), 'info', 5200);
            });
        </script>
    }

    @RenderSection("scripts", required: false)

</body>
</html>