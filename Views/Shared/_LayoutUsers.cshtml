@* Views/Shared/_LayoutUsers.cshtml *@
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewBag.Title – CampusEvents</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Lexend:wght@300;400;500;600;700;800&display=swap" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@20..48,100..700,0..1,-50..200" rel="stylesheet" />

    <!-- toastr CSS -->
    <link href="https://cdnjs.cloudflare.com/ajax/libs/toastr.js/latest/toastr.min.css" rel="stylesheet" />

    <link href="@Url.Content("~/Content/campus-variables.css")" rel="stylesheet" />
    <link href="@Url.Content("~/Content/campus-base.css")" rel="stylesheet" />
    <link href="@Url.Content("~/Content/campus-navbar.css")" rel="stylesheet" />
    <link href="@Url.Content("~/Content/campus-components.css")" rel="stylesheet" />
    <link href="@Url.Content("~/Content/campus-pages.css")" rel="stylesheet" />
    <link href="@Url.Content("~/Content/campus-filter.css")" rel="stylesheet" />
    <link href="@Url.Content("~/Content/campus-profile.css")" rel="stylesheet" />
    @RenderSection("styles", required: false)
</head>
<body>

    @Html.AntiForgeryToken()

    <nav class="ce-navbar">
        <a href="@Url.Action("Index", "Users")" class="ce-navbar__brand">
            <div class="ce-navbar__logo">
                <span class="material-symbols-outlined">school</span>
            </div>
            <span class="ce-navbar__name">CampusEvents</span>
        </a>

        <div class="ce-navbar__search d-none d-md-block">
            <form action="@Url.Action("Events", "// Xác nhận đăng ký sự kiện\r\n[HttpPost]\r\n[ValidateAntiForgeryToken]\r\npublic ActionResult ConfirmRegister(int eventId)\r\n{\r\n    string studentId = GetCurrentStudentId();\r\n\r\n    var ev = db.EVENTs.FirstOrDefault(e => e.MaEvent == eventId);\r\n    if (ev == null)\r\n    {\r\n        TempData[\"Error\"] = \"Sự kiện không tồn tại.\";\r\n        return RedirectToAction(\"EventDetail\", new { id = eventId });\r\n    }\r\n\r\n    DateTime now = DateTime.Now;\r\n\r\n    //KIỂM TRA CHƯA TỚI NGÀY ĐĂNG KÝ\r\n    if (ev.NgayBatDauDangKy.HasValue && now < ev.NgayBatDauDangKy.Value)\r\n    {\r\n        TempData[\"Error\"] = $\"Sự kiện này sẽ mở đăng ký vào lúc {ev.NgayBatDauDangKy.Value.ToString(\"HH:mm dd/MM/yyyy\")}.\";\r\n        return RedirectToAction(\"EventDetail\", new { id = eventId });\r\n    }\r\n\r\n    // KIỂM TRA ĐÃ QUÁ HẠN ĐĂNG KÝ\r\n    if (ev.NgayHetHanDangKy.HasValue && now.Date > ev.NgayHetHanDangKy.Value.Date)\r\n    {\r\n        TempData[\"Error\"] = \"Sự kiện này đã hết hạn đăng ký.\";\r\n        return RedirectToAction(\"EventDetail\", new { id = eventId });\r\n    }\r\n\r\n    // KIỂM TRA ĐÃ ĐĂNG KÝ RỒI\r\n    bool daDangKy = db.DangKySuKiens.Any(d =>\r\n        d.MaEvent == eventId && d.IDSinhVien == studentId && !d.TrangThai.ToLower().Contains(\"Hủy\"));\r\n\r\n    if (daDangKy)\r\n    {\r\n        TempData[\"Error\"] = \"Bạn đã đăng ký sự kiện này rồi.\";\r\n        return RedirectToAction(\"EventDetail\", new { id = eventId });\r\n    }\r\n\r\n    // KIỂM TRA ĐÃ ĐẦY CHỖ\r\n    var tinhTrang = db.vw_SoChoConLai.FirstOrDefault(v => v.MaEvent == eventId);\r\n    if (tinhTrang == null || tinhTrang.SoChoConLai <= 0)\r\n    {\r\n        TempData[\"Error\"] = \"Sự kiện này đã đầy (hết chỗ).\";\r\n        return RedirectToAction(\"EventDetail\", new { id = eventId });\r\n    }\r\n\r\n    try\r\n    {\r\n        var existingReg = db.DangKySuKiens\r\n            .FirstOrDefault(d => d.MaEvent == eventId && d.IDSinhVien == studentId);\r\n\r\n        if (existingReg != null)\r\n        {\r\n            existingReg.TrangThai = \"Đã đăng ký\";\r\n            existingReg.NgayDangKy = DateTime.Now;\r\n        }\r\n        else\r\n        {\r\n            db.DangKySuKiens.Add(new DangKySuKien\r\n            {\r\n                MaEvent = eventId,\r\n                IDSinhVien = studentId,\r\n                NgayDangKy = DateTime.Now,\r\n                TrangThai = \"Đã đăng ký\"\r\n            });\r\n        }\r\n\r\n        db.SaveChanges();\r\n        TempData[\"ShowSuccessModal\"] = true;\r\n        return RedirectToAction(\"EventDetail\", new { id = eventId });\r\n    }\r\n    catch (Exception ex)\r\n    {\r\n        var innerMsg = ex.InnerException?.InnerException?.Message ?? ex.Message;\r\n        TempData[\"Error\"] = \"Có lỗi xảy ra: \" + innerMsg;\r\n        return RedirectToAction(\"EventDetail\", new { id = eventId });\r\n    }\r\n}")" method="GET" class="ce-navbar__search d-none d-md-block">
                <span class="material-symbols-outlined si">search</span>
                <input type="search" name="keyword" placeholder="Tìm kiếm sự kiện…" id="navbar-search" value="@Request.QueryString["keyword"]" />
            </form>
        </div>

        <div class="ce-navbar__nav">
            <a href="@Url.Action("Index", "Users")" class="@(ViewBag.ActivePage == "home" ? "active" : "")">
                <span class="material-symbols-outlined">home</span> Trang chủ
            </a>
            <a href="@Url.Action("Events", "Events")" class="@(ViewBag.ActivePage == "events" ? "active" : "")">
                <span class="material-symbols-outlined">event</span> Sự kiện
            </a>
            <a href="@Url.Action("Registrations", "Registration")" class="@(ViewBag.ActivePage == "registrations" ? "active" : "")">
                <span class="material-symbols-outlined">assignment_turned_in</span> Đăng ký của tôi
            </a>
            <a href="@Url.Action("Schedule", "Schedule")" class="@(ViewBag.ActivePage == "schedule" ? "active" : "")">
                <span class="material-symbols-outlined">calendar_month</span> Lịch của tôi
            </a>
        </div>

        <div class="ce-navbar__actions">
            <button class="ce-navbar__icon-btn" data-action="toggle-theme" title="Đổi giao diện">
                <span class="material-symbols-outlined ce-theme-icon">light_mode</span>
            </button>
            <button class="ce-navbar__icon-btn d-none d-sm-flex" title="Thông báo"
                    onclick="ceOpenModal('modal-notif')">
                <span class="material-symbols-outlined">notifications</span>
                <span class="ce-notif-dot"></span>
            </button>
            @if (Request.Cookies["jwt"] != null && school_event_management.Models.JwtService.ValidateToken(Request.Cookies["jwt"].Value) != null)
            {
                @* TRƯỜNG HỢP: ĐÃ ĐĂNG NHẬP *@
                <div class="dropdown">
                    <a href="#" class="ce-navbar__avatar" data-bs-toggle="dropdown" aria-expanded="false" title="Tài khoản">
                        @{
                            var name = ViewBag.UserName as string ?? "SV";
                            var initials = name.Length >= 2 ? name.Substring(0, 2).ToUpper() : name.ToUpper();
                        }
                        @initials
                    </a>
                    <ul class="dropdown-menu dropdown-menu-end shadow-sm border-0" style="border-radius: 12px; margin-top: 10px; background: var(--surface);">
                        <li><a class="dropdown-item py-2" href="@Url.Action("Profile", "Users")" style="color: var(--text)"><span class="material-symbols-outlined v-align-middle me-2" style="font-size:20px; color: var(--text);">person</span> Hồ sơ cá nhân</a></li>
                        <li><hr class="dropdown-divider"></li>
                        <li><a class="dropdown-item py-2" href="@Url.Action("Registrations", "Registration")" style="color: var(--text)"><span class="material-symbols-outlined v-align-middle me-" style="font-size:20px; color: var(--text);">assignment_turned_in</span> Tổng quan đăng ký</a></li>
                        <li><hr class="dropdown-divider"></li>
                        <li><a class="dropdown-item py-2 text-danger" href="@Url.Action("Logout", "Account")"><span class="material-symbols-outlined v-align-middle me-2" style="font-size:20px;">logout</span> Đăng xuất</a></li>
                    </ul>
                </div>
            }
            else
            {
                @* TRƯỜNG HỢP: CHƯA ĐĂNG NHẬP *@
                <a href="@Url.Action("Login", "Account")" class="ce-navbar__login-btn d-flex align-items-center gap-2" title="Đăng nhập hệ thống">
                    <div class="ce-navbar__avatar-guest">
                        <span class="material-symbols-outlined" style="font-size: 20px; color: var(--text-muted);">person</span>
                    </div>
                    <span class="d-none d-sm-inline" style="font-size: 0.85rem; font-weight: 600; color: var(--text);">Đăng nhập</span>
                </a>
            }
            <button class="ce-navbar__toggler" id="ce-nav-toggler" aria-label="Menu">
                <span class="material-symbols-outlined">menu</span>
            </button>
        </div>
    </nav>

    <div class="ce-mobile-menu" id="ce-mobile-menu">
        <div class="ce-mobile-menu__content">
            <div class="ce-mobile-menu__header">
                <span class="ce-navbar__name">Menu</span>
            </div>
            <div class="ce-mobile-menu__nav">
                <a href="@Url.Action("Index", "Users")" class="@(ViewBag.ActivePage == "home" ? "active" : "")">
                    <span class="material-symbols-outlined">home</span> Trang chủ
                </a>
                <a href="@Url.Action("Events", "Users")" class="@(ViewBag.ActivePage == "events" ? "active" : "")">
                    <span class="material-symbols-outlined">event</span> Sự kiện
                </a>
                <a href="@Url.Action("Registrations", "Registration")" class="@(ViewBag.ActivePage == "registrations" ? "active" : "")">
                    <span class="material-symbols-outlined">assignment_turned_in</span> Đăng ký của tôi
                </a>
                <a href="@Url.Action("Schedule", "Users")" class="@(ViewBag.ActivePage == "schedule" ? "active" : "")">
                    <span class="material-symbols-outlined">calendar_month</span> Lịch của tôi
                </a>
            </div>
        </div>
    </div>

    <!-- Mobile Menu và Notification Modal giữ nguyên như cũ của bạn -->
    @* ── PAGE WRAPPER ── *@
    <div class="ce-page-wrapper">
        <main class="ce-main">
            @RenderSection("Hero", required: false)
            @RenderBody()
        </main>

        <footer style="background:var(--surface);border-top:1px solid var(--border);padding:1.75rem 0;margin-top:2rem">
            <div class="container">
                <div class="row align-items-center g-3">
                    <div class="col-md-6">
                        <div class="d-flex align-items-center gap-2 mb-1">
                            <div style="width:26px;height:26px;background:var(--primary);border-radius:6px;display:flex;align-items:center;justify-content:center;color:#fff">
                                <span class="material-symbols-outlined" style="font-size:15px">school</span>
                            </div>
                            <span style="font-weight:700;font-size:.9rem">CampusEvents</span>
                        </div>
                        <p style="font-size:.78rem;color:var(--text-muted);margin:0">Cổng thông tin sự kiện sinh viên – Trường Đại học ABC</p>
                    </div>
                    <div class="col-md-6 text-md-end">
                        <p style="font-size:.75rem;color:var(--text-muted);margin:0">© 2025 CampusEvents · Tất cả quyền được bảo lưu</p>
                    </div>
                </div>
            </div>
        </footer>
    </div>

    <!-- Scripts -->
    <script src="https://cdn.jsdelivr.net/npm/jquery@3.7.1/dist/jquery.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>

    <!-- toastr JS -->
    <script src="https://cdnjs.cloudflare.com/ajax/libs/toastr.js/latest/toastr.min.js"></script>

    <script src="@Url.Content("~/Scripts/campus-app.js")"></script>

    @RenderSection("scripts", required: false)

</body>
</html>