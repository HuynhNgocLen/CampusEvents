@* Views/Shared/_LayoutUsers.cshtml *@
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewBag.Title – CampusEvents</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Lexend:wght@300;400;500;600;700;800&display=swap" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@20..48,100..700,0..1,-50..200" rel="stylesheet" />

    <link href="https://cdnjs.cloudflare.com/ajax/libs/toastr.js/latest/toastr.min.css" rel="stylesheet" />

    <link href="@Url.Content("~/Content/campus-variables.css")" rel="stylesheet" />
    <link href="@Url.Content("~/Content/campus-base.css")" rel="stylesheet" />
    <link href="@Url.Content("~/Content/campus-navbar.css")" rel="stylesheet" />
    <link href="@Url.Content("~/Content/campus-components.css")" rel="stylesheet" />
    <link href="@Url.Content("~/Content/campus-pages.css")" rel="stylesheet" />

    @RenderSection("styles", required: false)

    <style>
        /* Đảm bảo navbar luôn nổi lên trên cùng để chứa dropdown */
        .ce-navbar {
            position: relative;
            z-index: 1050;
        }

        /* Lớp phủ làm mờ nội dung phía dưới */
        .ce-mobile-backdrop {
            position: fixed;
            top: 0;
            left: 0;
            width: 100vw;
            height: 100vh;
            background: rgba(0, 0, 0, 0.4); /* Nền đen mờ nhẹ */
            backdrop-filter: blur(5px); /* Hiệu ứng mờ (Blur) */
            -webkit-backdrop-filter: blur(5px);
            z-index: 1040; /* Nằm ngay dưới navbar */
            opacity: 0;
            visibility: hidden;
            transition: all 0.3s ease;
        }

            /* Hiện lớp phủ khi được kích hoạt */
            .ce-mobile-backdrop.show {
                opacity: 1;
                visibility: visible;
            }

        /* Khung Mobile Menu được thiết kế lại */
        .ce-mobile-menu-wrapper {
            background: var(--surface);
            border-bottom: 1px solid var(--border);
            box-shadow: 0 10px 30px rgba(0,0,0,0.1);
            position: absolute;
            top: 100%;
            left: 0;
            width: 100%;
            z-index: 1051;
            border-bottom-left-radius: 16px;
            border-bottom-right-radius: 16px;
        }

            /* Các nút bấm bên trong menu */
            .ce-mobile-menu-wrapper .nav-link-mobile {
                display: flex;
                align-items: center;
                padding: 12px 18px;
                color: var(--text);
                font-weight: 500;
                text-decoration: none;
                border-radius: 10px;
                margin-bottom: 8px;
                transition: all 0.2s ease;
            }

                /* Đổi màu khi chạm/hover */
                .ce-mobile-menu-wrapper .nav-link-mobile:hover,
                .ce-mobile-menu-wrapper .nav-link-mobile:active {
                    background: var(--primary);
                    color: #fff;
                }

                .ce-mobile-menu-wrapper .nav-link-mobile .material-symbols-outlined {
                    margin-right: 12px;
                    font-size: 24px;
                    color: var(--text-muted);
                    transition: color 0.2s ease;
                }

                .ce-mobile-menu-wrapper .nav-link-mobile:hover .material-symbols-outlined,
                .ce-mobile-menu-wrapper .nav-link-mobile:active .material-symbols-outlined {
                    color: #fff;
                }
    </style>
</head>
<body>

    @Html.AntiForgeryToken()

    @* ── BACKDROP LÀM MỜ SẼ NẰM Ở ĐÂY ── *@
    <div id="ce-blur-backdrop" class="ce-mobile-backdrop"></div>

    @* ── NAVBAR ── *@
    <nav class="ce-navbar">
        <a href="@Url.Action("Index", "Users")" class="ce-navbar__brand">
            <div class="ce-navbar__logo">
                <span class="material-symbols-outlined">school</span>
            </div>
            <span class="ce-navbar__name">CampusEvents</span>
        </a>

        <div class="ce-navbar__search d-none d-md-block">
            <span class="material-symbols-outlined si">search</span>
            <input type="search" placeholder="Tìm kiếm sự kiện…" id="navbar-search" />
        </div>

        <div class="ce-navbar__nav">
            <a href="@Url.Action("Index", "Users")" class="@(ViewBag.ActivePage == "home" ? "active" : "")">
                <span class="material-symbols-outlined">home</span> Trang chủ
            </a>
            <a href="@Url.Action("Events", "Users")" class="@(ViewBag.ActivePage == "events" ? "active" : "")">
                <span class="material-symbols-outlined">event</span> Sự kiện
            </a>
            <a href="@Url.Action("Registrations", "Users")" class="@(ViewBag.ActivePage == "registrations" ? "active" : "")">
                <span class="material-symbols-outlined">assignment_turned_in</span> Đăng ký của tôi
            </a>
            <a href="@Url.Action("Schedule", "Users")" class="@(ViewBag.ActivePage == "schedule" ? "active" : "")">
                <span class="material-symbols-outlined">calendar_month</span> Lịch của tôi
            </a>
        </div>

        <div class="ce-navbar__actions" style="display: flex; align-items: center; gap: 0.6rem;">

            @* ── Nút Đổi giao diện: CHỈ HIỆN TRÊN DESKTOP (d-none d-md-flex) ── *@
            <button class="ce-navbar__icon-btn d-none d-md-flex" data-action="toggle-theme" title="Đổi giao diện"
                    style="width: 40px; height: 40px; align-items: center; justify-content: center; border-radius: 12px; background: var(--surface); border: 1px solid var(--border); cursor: pointer;">
                <span class="material-symbols-outlined ce-theme-icon" style="color: var(--text-muted); font-size: 22px;">light_mode</span>
            </button>

            @if (Session["StudentId"] != null)
            {
                @* ── Nút Thông báo: CHỈ HIỆN TRÊN DESKTOP (d-none d-md-flex) ── *@
                <button class="ce-navbar__icon-btn d-none d-md-flex" title="Thông báo" onclick="ceOpenModal('modal-notif')"
                        style="width: 40px; height: 40px; align-items: center; justify-content: center; border-radius: 12px; background: var(--surface); border: 1px solid var(--border); cursor: pointer; position: relative;">
                    <span class="material-symbols-outlined" style="color: var(--text-muted); font-size: 22px;">notifications</span>
                    <span class="ce-notif-dot" style="position: absolute; top: 10px; right: 10px; width: 8px; height: 8px; background-color: #ef4444; border-radius: 50%; border: 2px solid var(--surface);"></span>
                </button>

                @* ── Avatar Sinh viên: LUÔN HIỆN TRÊN MỌI THIẾT BỊ ── *@
                <a href="@Url.Action("Registrations", "Users")" title="Hồ sơ cá nhân"
                   style="width: 40px; height: 40px; display: flex; align-items: center; justify-content: center; border-radius: 50%; background: #f0f7ff; border: 2px solid #3b82f6; text-decoration: none; color: #3b82f6; font-weight: 700; font-size: 0.9rem;">
                    @{
                        var name = Session["UserName"] as string;
                        if (string.IsNullOrWhiteSpace(name)) { name = "SV"; }
                        var words = name.Trim().Split(new char[] { ' ' }, StringSplitOptions.RemoveEmptyEntries);
                        var initials = "SV";
                        if (words.Length > 0)
                        {
                            initials = words[words.Length - 1].Substring(0, 1).ToUpper();
                            if (words.Length >= 2)
                            {
                                var apChot = words[words.Length - 2].Substring(0, 1).ToUpper();
                                initials = apChot + initials;
                            }
                        }
                    }
                    @initials
                </a>

                @* ── Nút Đăng xuất: CHỈ HIỆN TRÊN DESKTOP (d-none d-md-flex) ── *@
                <a href="@Url.Action("Logout", "Account")" title="Đăng xuất" class="d-none d-md-flex"
                   style="width: 40px; height: 40px; align-items: center; justify-content: center; border-radius: 12px; background: var(--surface); border: 1px solid var(--border); text-decoration: none;">
                    <span class="material-symbols-outlined" style="color: #ef4444; font-size: 22px;">logout</span>
                </a>
            }
            else
            {
                @* ── Nút Đăng nhập: CHỈ HIỆN TRÊN DESKTOP (d-none d-md-flex) ── *@
                <a href="@Url.Action("Login", "Account")" title="Đăng nhập hệ thống" class="d-none d-md-flex"
                   style="align-items: center; gap: 8px; height: 40px; padding: 0 1.2rem; border-radius: 12px; background: var(--primary); color: #fff; text-decoration: none; font-weight: 600; font-size: 0.9rem; transition: opacity 0.2s;">
                    <span class="material-symbols-outlined" style="font-size: 20px;">login</span>
                    <span>Đăng nhập</span>
                </a>
            }

            <button class="ce-navbar__toggler d-md-none" id="ce-nav-toggler" aria-label="Menu"
                    data-bs-toggle="collapse" data-bs-target="#MobileMenuCollapse"
                    style="background: none; border: none; padding: 0; color: var(--text); display: flex; align-items: center;">
                <span class="material-symbols-outlined" style="font-size: 28px;">menu</span>
            </button>
        </div>

        @* ── ĐƯA MENU VÀO TRONG NAVBAR ĐỂ KHÔNG BỊ MẤT KHI CUỘN ── *@
        <div class="collapse d-md-none ce-mobile-menu-wrapper" id="MobileMenuCollapse">
            <div class="p-3">
                <a href="@Url.Action("Index", "Users")" class="nav-link-mobile">
                    <span class="material-symbols-outlined">home</span> Trang chủ
                </a>
                <a href="@Url.Action("Events", "Users")" class="nav-link-mobile">
                    <span class="material-symbols-outlined">event</span> Sự kiện
                </a>
                <a href="@Url.Action("Registrations", "Users")" class="nav-link-mobile">
                    <span class="material-symbols-outlined">assignment_turned_in</span> Đăng ký của tôi
                </a>
                <a href="@Url.Action("Schedule", "Users")" class="nav-link-mobile">
                    <span class="material-symbols-outlined">calendar_month</span> Lịch của tôi
                </a>

                @* ── ĐƯỜNG KẺ NGANG ĐỂ TÁCH BIỆT MENU CHÍNH VÀ MENU CHỨC NĂNG ── *@
                <hr style="border-top: 1px solid var(--border); margin: 12px 18px; opacity: 1;">

                @* ── CÁC CHỨC NĂNG ĐƯỢC CHUYỂN VÀO MOBILE MENU ── *@
                <a href="#" class="nav-link-mobile" data-action="toggle-theme">
                    <span class="material-symbols-outlined">light_mode</span> Đổi giao diện
                </a>

                @if (Session["StudentId"] != null)
                {
                    <a href="#" class="nav-link-mobile" onclick="ceOpenModal('modal-notif'); return false;">
                        <span class="material-symbols-outlined">notifications</span> Thông báo
                    </a>

                    <a href="@Url.Action("Logout", "Account")" class="nav-link-mobile">
                        <span class="material-symbols-outlined" style="color: #ef4444;">logout</span>
                        <span style="color: #ef4444;">Đăng xuất</span>
                    </a>
                }
                else
                {
                    <a href="@Url.Action("Login", "Account")" class="nav-link-mobile">
                        <span class="material-symbols-outlined">login</span> Đăng nhập
                    </a>
                }
            </div>
        </div>
    </nav>

    @* ── PAGE WRAPPER ── *@
    <div class="ce-page-wrapper">
        <main class="ce-main">
            @RenderSection("Hero", required: false)
            @RenderBody()
        </main>

        <footer style="background:var(--surface);border-top:1px solid var(--border);padding:1.75rem 0;margin-top:2rem">
            <div class="container">
                <div class="row align-items-center g-3">
                    <div class="col-md-6">
                        <div class="d-flex align-items-center gap-2 mb-1">
                            <div style="width:26px;height:26px;background:var(--primary);border-radius:6px;display:flex;align-items:center;justify-content:center;color:#fff">
                                <span class="material-symbols-outlined" style="font-size:15px">school</span>
                            </div>
                            <span style="font-weight:700;font-size:.9rem">CampusEvents</span>
                        </div>
                        <p style="font-size:.78rem;color:var(--text-muted);margin:0">Cổng thông tin sự kiện sinh viên – Trường Đại học ABC</p>
                    </div>
                    <div class="col-md-6 text-md-end">
                        <p style="font-size:.75rem;color:var(--text-muted);margin:0">© 2025 CampusEvents · Tất cả quyền được bảo lưu</p>
                    </div>
                </div>
            </div>
        </footer>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/jquery@3.7.1/dist/jquery.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/toastr.js/latest/toastr.min.js"></script>
    <script src="@Url.Content("~/Scripts/campus-app.js")"></script>

    <script>
        document.addEventListener("DOMContentLoaded", function () {
            var mobileMenu = document.getElementById('MobileMenuCollapse');
            var backdrop = document.getElementById('ce-blur-backdrop');
            var togglerBtn = document.getElementById('ce-nav-toggler');

            if (mobileMenu && backdrop) {
                // Khi menu mở -> Hiện backdrop làm mờ & Khóa cuộn trang
                mobileMenu.addEventListener('show.bs.collapse', function () {
                    backdrop.classList.add('show');
                    document.body.style.overflow = 'hidden';
                });

                // Khi menu đóng -> Ẩn backdrop làm mờ & Cho phép cuộn lại
                mobileMenu.addEventListener('hide.bs.collapse', function () {
                    backdrop.classList.remove('show');
                    document.body.style.overflow = '';
                });

                // Tùy chọn cực hay: Click vào phần nền mờ sẽ tự động đóng Menu
                backdrop.addEventListener('click', function () {
                    var bsCollapse = bootstrap.Collapse.getInstance(mobileMenu);
                    if (bsCollapse) {
                        bsCollapse.hide();
                    }
                });
            }
        });
    </script>

    @RenderSection("scripts", required: false)
</body>
</html>